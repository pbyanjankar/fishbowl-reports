	INNER JOIN ObjectToObject ON ObjectToObject.typeId = 30 AND  recordId1 = shipitem.soitemid
	WHERE shipid = $P{shipID}
	GROUP BY recordId2
) AS kitproductshipping ON kitproductshipping.recordId2 = soitem.id
left join
(
select soitemid as soitemid,recordId2 as KitParentId, sum(qtyshipped) as totalshipped from shipitem
LEFT JOIN ObjectToObject ON ObjectToObject.typeId =30 AND recordid1 = shipitem.soitemid
where
shipid in
