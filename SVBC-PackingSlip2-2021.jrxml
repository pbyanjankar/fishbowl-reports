	<subDataset name="Cartons" uuid="6a0ca1be-c791-429d-90c5-e0b6f20ab819">
		<parameter name="soNum" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT SO.NUM AS SONUM, SHIPCARTON.CARTONNUM AS CARTNUM, SHIPCARTON.TRACKINGNUM AS TRACKNUM,
  SHIPCARTON.FREIGHTWEIGHT AS WT, SHIPCARTON.WEIGHTUOM AS WTUOM

FROM SO
  JOIN SOITEM ON SOITEM.SOID = SO.ID
  JOIN SHIPITEM ON SHIPITEM.SOITEMID = SOITEM.ID
  JOIN SHIPCARTON ON SHIPCARTON.ID = SHIPITEM.SHIPCARTONID

WHERE SO.NUM = $P{soNum}

GROUP BY SHIPCARTON.ID
ORDER BY SHIPCARTON.CARTONNUM]]>
		</queryString>
		<field name="SONUM" class="java.lang.String"/>
		<field name="CARTNUM" class="java.lang.Integer"/>
		<field name="TRACKNUM" class="java.lang.String"/>
		<field name="WT" class="java.math.BigDecimal"/>
		<field name="WTUOM" class="java.lang.String"/>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="Items" uuid="b02aa67b-a9ec-421f-8b0d-ca89d4af60e2">
		<parameter name="soNum" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT SO.NUM AS SONUM,
  SOITEM.ID AS SOITEMID,
  SOITEM.SOLINEITEM AS LINE,
  SOITEM.PRODUCTNUM,
  SOITEM.DESCRIPTION AS PRODUCTDESC,
  SOITEMTYPE.NAME AS ITEMTYPE,
  PART.NUM PARTNUM,
  PART.DESCRIPTION PARTDESC,
  SOITEM.NOTE AS ITEMNOTE,
  SOITEM.DESCRIPTION AS ITEMDESC,
  SOITEM.QTYTOFULFILL,
  SOITEM.QTYFULFILLED,
  SOITEM.QTYPICKED,
  SOITEM.UNITPRICE,
# SOITEM.TOTALPRICE,
  SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL AS TOTALPRICE,
# TOTAL.SOTAX * SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL / TOTAL.TAXABLESUBTOTAL AS ITEMTAX,
# SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL * (1 + SOITEM.TAXABLEFLAG * TOTAL.SOTAX / TOTAL.TAXABLESUBTOTAL) AS ITEMTAXEDTOTAL,
  UOM.CODE AS UOM,
# SOITEM.CUSTOMERPARTNUM AS CONDISH
# CustomFieldByName(SOITEM.CUSTOMFIELDS, 'Condition') AS CONDISH
  ITEMCLASS.NAME AS CONDISH

FROM SO
  LEFT JOIN SOITEM ON SOITEM.SOID = SO.ID AND SOITEM.TYPEID NOT IN(40,90)
  LEFT JOIN SOITEMTYPE ON SOITEMTYPE.ID = SOITEM.TYPEID
  LEFT JOIN OBJECTTOOBJECT OTO ON OTO.RECORDID1 = SOITEM.ID AND OTO.TYPEID = 30
  LEFT JOIN UOM ON UOM.ID = SOITEM.UOMID
  LEFT JOIN PRODUCT ON PRODUCT.ID = SOITEM.PRODUCTID
  LEFT JOIN PART ON PART.ID = PRODUCT.PARTID
  LEFT JOIN QBCLASS ITEMCLASS ON ITEMCLASS.ID = SOITEM.QBCLASSID

WHERE SO.NUM = $P{soNum}
  AND COALESCE(OTO.TYPEID,0) != 30

GROUP BY SOITEMID

ORDER BY LINE]]>
		</queryString>
		<field name="SONUM" class="java.lang.String"/>
		<field name="SOITEMID" class="java.lang.Integer"/>
		<field name="LINE" class="java.lang.Integer"/>
		<field name="PRODUCTNUM" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="PRODUCTDESC" class="java.lang.String"/>
		<field name="ITEMTYPE" class="java.lang.String"/>
		<field name="PARTNUM" class="java.lang.String"/>
		<field name="PARTDESC" class="java.lang.String"/>
		<field name="ITEMNOTE" class="java.lang.String"/>
		<field name="ITEMDESC" class="java.lang.String"/>
		<field name="QTYTOFULFILL" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="QTYFULFILLED" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="QTYPICKED" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="UNITPRICE" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="TOTALPRICE" class="java.math.BigDecimal">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="UOM" class="java.lang.String"/>
		<field name="CONDISH" class="java.lang.String"/>
		<variable name="DateFormat" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
