	<subDataset name="New Dataset 1" uuid="0b469340-b56a-4449-86df-55ac4f01e942">
		<parameter name="partNum" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
		</parameter>
		<parameter name="ckIncludeReturns" class="java.lang.String" isForPrompting="false">
			<property name="Group" value="Other Settings"/>
			<parameterDescription><![CDATA[20,0]]></parameterDescription>
			<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT
    PART.NUM AS PART,
    PART.DESCRIPTION,
    UOM.CODE AS UOMCODE,
    (SELECT NAME FROM COMPANY WHERE ID = 1) AS COMPANY,
    COALESCE(invAtx.TOTALONHAND,0) AS AtxQTY,
    COALESCE(invAtx.TOTALNOTAVAILABLE,0) AS AtxUNAVAILABLE,
    COALESCE(invAtx.TOTALDROPSHIP,0) AS AtxDROPSHIP,

    COALESCE(invAtx.TOTALALLOCATED,0) AS AtxALLOCATED,
    COALESCE(invAtx.TOTALONORDER,0) AS AtxONORDER,
    COALESCE(invAtx.totalNotAvailabletopick,0) AtxtotalNotAvailabletopick,

    COALESCE(invAtxNew.TOTALONHAND,0) AS AtxNewQTY,
    COALESCE(invAtxNew.TOTALNOTAVAILABLE,0) AS AtxNewUNAVAILABLE,
    COALESCE(invAtxNew.TOTALDROPSHIP,0) AS AtxNewDROPSHIP,

    COALESCE(invAtxNew.TOTALALLOCATED,0) AS AtxNewALLOCATED,
    COALESCE(invAtxNew.TOTALONORDER,0) AS AtxNewONORDER,
    COALESCE(invAtxNew.totalNotAvailabletopick,0) AtxNewtotalNotAvailabletopick,

    COALESCE(invJax.TOTALONHAND,0) AS JaxQTY,
    COALESCE(invJax.TOTALNOTAVAILABLE,0) AS JaxUNAVAILABLE,
    COALESCE(invJax.TOTALDROPSHIP,0) AS JaxDROPSHIP,

    COALESCE(invJax.TOTALALLOCATED,0) AS JaxALLOCATED,
    COALESCE(invJax.TOTALONORDER,0) AS JaxONORDER,
    COALESCE(invJax.totalNotAvailabletopick,0) JaxtotalNotAvailabletopick,


    COALESCE(invTPA.TOTALONHAND,0) AS TPAQTY,
    COALESCE(invTPA.TOTALNOTAVAILABLE,0) AS TPAUNAVAILABLE,
    COALESCE(invTPA.TOTALDROPSHIP,0) AS TPADROPSHIP,

    COALESCE(invTPA.TOTALALLOCATED,0) AS TPAALLOCATED,
    COALESCE(invTPA.TOTALONORDER,0) AS TPAONORDER,
    COALESCE(invTPA.totalNotAvailabletopick,0) TPAtotalNotAvailabletopick,

 COALESCE(invORL.TOTALONHAND,0) AS ORLQTY,
    COALESCE(invORL.TOTALNOTAVAILABLE,0) AS ORLUNAVAILABLE,
    COALESCE(invORL.TOTALDROPSHIP,0) AS ORLDROPSHIP,

    COALESCE(invORL.TOTALALLOCATED,0) AS ORLALLOCATED,
    COALESCE(invORL.TOTALONORDER,0) AS ORLONORDER,
    COALESCE(invORL.totalNotAvailabletopick,0) ORLtotalNotAvailabletopick,

COALESCE(invORLNew.TOTALONHAND,0) AS ORLNewQTY,
    COALESCE(invORLNew.TOTALNOTAVAILABLE,0) AS ORLNewUNAVAILABLE,
    COALESCE(invORLNew.TOTALDROPSHIP,0) AS ORLNewDROPSHIP,

    COALESCE(invORLNew.TOTALALLOCATED,0) AS ORLNewALLOCATED,
    COALESCE(invORLNew.TOTALONORDER,0) AS ORLNewONORDER,
    COALESCE(invORLNew.totalNotAvailabletopick,0) ORLNewtotalNotAvailabletopick,

    COALESCE(invNola.TOTALONHAND,0) AS NolaQTY,
    COALESCE(invNola.TOTALNOTAVAILABLE,0) AS NolaUNAVAILABLE,
    COALESCE(invNola.TOTALDROPSHIP,0) AS NolaDROPSHIP,

    COALESCE(invNola.TOTALALLOCATED,0) AS NolaALLOCATED,
    COALESCE(invNola.TOTALONORDER,0) AS NolaONORDER,
    COALESCE(invNola.totalNotAvailabletopick,0) NolatotalNotAvailabletopick,

    0 AS DCQTY,
    COALESCE(invDC.TOTALNOTAVAILABLE,0) AS DCUNAVAILABLE,
    0 AS DCDROPSHIP,

    0 AS DCALLOCATED,
    0 AS DCONORDER,
    0 DCtotalNotAvailabletopick,

COALESCE(invNSH.TOTALONHAND,0) AS NSHQTY,
    COALESCE(invNSH.TOTALNOTAVAILABLE,0) AS NSHUNAVAILABLE,
    COALESCE(invNSH.TOTALDROPSHIP,0) AS NSHDROPSHIP,

    COALESCE(invNSH.TOTALALLOCATED,0) AS NSHALLOCATED,
    COALESCE(invNSH.TOTALONORDER,0) AS NSHONORDER,
    COALESCE(invNSH.totalNotAvailabletopick,0) NSHtotalNotAvailabletopick,

coalesce((select sum(qtytofulfill-qtyfulfilled) from poitem
inner join po on po.id=poitem.poid
where po.statusid=10 and poitem.partid=part.id and po.locationgroupid=1),0) as ATXBid,

coalesce((select sum(qtytofulfill-qtyfulfilled) from poitem
inner join po on po.id=poitem.poid
where po.statusid=10 and poitem.partid=part.id and po.locationgroupid=10),0) as ATXNewBid,

COALESCE((SELECT SUM(qtytofulfill-qtyfulfilled) FROM poitem
INNER JOIN po ON po.id=poitem.poid
WHERE po.statusid=10 AND poitem.partid=part.id AND po.locationgroupid=9),0) AS JAXBid,
COALESCE((SELECT SUM(qtytofulfill-qtyfulfilled) FROM poitem
INNER JOIN po ON po.id=poitem.poid
WHERE po.statusid=10 AND poitem.partid=part.id AND po.locationgroupid=3),0) AS TPABid,

COALESCE((SELECT SUM(qtytofulfill-qtyfulfilled) FROM poitem
INNER JOIN po ON po.id=poitem.poid
WHERE po.statusid=10 AND poitem.partid=part.id AND po.locationgroupid=4),0) AS ORLBid,

COALESCE((SELECT SUM(qtytofulfill-qtyfulfilled) FROM poitem
INNER JOIN po ON po.id=poitem.poid
WHERE po.statusid=10 AND poitem.partid=part.id AND po.locationgroupid=8),0) AS ORLNewBid,

COALESCE((SELECT SUM(qtytofulfill-qtyfulfilled) FROM poitem
INNER JOIN po ON po.id=poitem.poid
WHERE po.statusid=10 AND poitem.partid=part.id AND po.locationgroupid=5),0) AS NOLABid,

0 AS DCBid,

COALESCE((SELECT SUM(qtytofulfill-qtyfulfilled) FROM poitem
INNER JOIN po ON po.id=poitem.poid
WHERE po.statusid=10 AND poitem.partid=part.id AND po.locationgroupid=7),0) AS NSHBid,
coalesce(prAtx.orderuptolevel,0) as atxOL,
coalesce(prAtxNew.orderuptolevel,0) as atxNewOL,
coalesce(prJax.orderuptolevel,0) as jaxOL,
coalesce(prTPA.orderuptolevel,0) as tpaOL,
coalesce(prORL.orderuptolevel,0) as orlOL,
coalesce(prORLNew.orderuptolevel,0) as orlNewOL,
coalesce(prNOLA.orderuptolevel,0) as nolaOL,
0 as dcOL
,
coalesce(prNSH.orderuptolevel,0) as nshOL,
coalesce(prAtx.reorderpoint,0) as atxRP,
coalesce(prAtxNew.reorderpoint,0) as atxNewRP,
coalesce(prJax.reorderpoint,0) as jaxRP,
coalesce(prTPA.reorderpoint,0) as tpaRP,
coalesce(prORL.reorderpoint,0) as orlRP,
coalesce(prORLNew.reorderpoint,0) as orlNewRP,
coalesce(prNOLA.reorderpoint,0) as nolaRP,
coalesce(prDC.reorderpoint,0) as dcRP,
coalesce(prNSH.reorderpoint,0) as nshRP,
COALESCE(atxLast6.last6,0) AS ATXLast6mnts,
COALESCE(atxNewLast6.last6,0) AS ATXNewLast6mnts,
COALESCE(jaxLast6.last6,0) AS JAXLast6mnts,
COALESCE(tpaLast6.last6,0) AS  TPALast6mnts,
COALESCE(orlLast6.last6,0) AS ORLLast6mnts,
COALESCE(orlNewLast6.last6,0) AS ORLNewLast6mnts,
COALESCE(nolaLast6.last6,0) AS NOLALast6mnts,
0 AS DCLast6mnts,
COALESCE(nshLast6.last6,0) AS NSHLast6mnts,

COALESCE(invAll.TOTALONHAND,0) AS AllQTY,
    COALESCE(invAll.TOTALNOTAVAILABLE,0) AS AllUNAVAILABLE,
    COALESCE(invAll.TOTALDROPSHIP,0) AS AllDROPSHIP,

    COALESCE(invAll.TOTALALLOCATED,0) AS AllALLOCATED,
    COALESCE(invAll.TOTALONORDER,0) AS AllONORDER,
    COALESCE(invAll.totalNotAvailabletopick,0) AllotalNotAvailabletopick,
CustomFieldByName(part.CUSTOMFIELDS, 'Part Category') AS PartCategory,
CustomFieldByName(part.CUSTOMFIELDS, 'cu ft (Each)') AS cuftEach,
upper(CustomFieldByName(part.CUSTOMFIELDS, 'Key Item')) AS KeyItem








FROM
    part
    LEFT JOIN uom ON part.uomid = uom.id


LEFT JOIN (
        SELECT
            partId,
            SUM(qtyOnHand) AS totalOnHand,
            SUM(qtyNotAvailable) AS totalNotAvailable,
            SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
            SUM(qtyDropship) AS totalDropship,
            SUM(qtyAllocated) AS totalAllocated,
            SUM(qtyOnOrder) AS totalOnOrder
        FROM
            qtyInventoryTotals

        GROUP BY partId
    ) AS invAll ON invAll .partId = part.id

    LEFT JOIN (
        SELECT
            partId,
            SUM(qtyOnHand) AS totalOnHand,
            SUM(qtyNotAvailable) AS totalNotAvailable,
            SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
            SUM(qtyDropship) AS totalDropship,
            SUM(qtyAllocated) AS totalAllocated,
            SUM(qtyOnOrder) AS totalOnOrder
        FROM
            qtyInventoryTotals
        WHERE locationGroupId IN (1)
        GROUP BY partId
    ) AS invAtx ON invAtx .partId = part.id
left join partreorder prAtx on prAtx.partid=part.id and prAtx.locationgroupid=1


LEFT JOIN (
        SELECT
            partId,
            SUM(qtyOnHand) AS totalOnHand,
            SUM(qtyNotAvailable) AS totalNotAvailable,
            SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
            SUM(qtyDropship) AS totalDropship,
            SUM(qtyAllocated) AS totalAllocated,
            SUM(qtyOnOrder) AS totalOnOrder
        FROM
            qtyInventoryTotals
        WHERE locationGroupId IN (10)
        GROUP BY partId
    ) AS invAtxNew ON invAtxNew.partId = part.id
left join partreorder prAtxNew on prAtxNew.partid=part.id and prAtxNew.locationgroupid=10

    LEFT JOIN (
        SELECT
            partId,
            SUM(qtyOnHand) AS totalOnHand,
            SUM(qtyNotAvailable) AS totalNotAvailable,
            SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
            SUM(qtyDropship) AS totalDropship,
            SUM(qtyAllocated) AS totalAllocated,
            SUM(qtyOnOrder) AS totalOnOrder
        FROM
            qtyInventoryTotals
        WHERE locationGroupId IN (9)
        GROUP BY partId
    ) AS invJax ON invJax.partId = part.id
left join partreorder prJax on prJax.partid=part.id and prJax.locationgroupid=9
    LEFT JOIN (
        SELECT
            partId,
            SUM(qtyOnHand) AS totalOnHand,
            SUM(qtyNotAvailable) AS totalNotAvailable,
            SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
            SUM(qtyDropship) AS totalDropship,
            SUM(qtyAllocated) AS totalAllocated,
            SUM(qtyOnOrder) AS totalOnOrder
        FROM
            qtyInventoryTotals
        WHERE locationGroupId IN (3)
        GROUP BY partId
    ) AS invTPA ON invTPA.partId = part.id

left join partreorder prTPA on prTPA.partid=part.id and prTPA.locationgroupid=3

    LEFT JOIN (
        SELECT
            partId,
            SUM(qtyOnHand) AS totalOnHand,
            SUM(qtyNotAvailable) AS totalNotAvailable,
            SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
            SUM(qtyDropship) AS totalDropship,
            SUM(qtyAllocated) AS totalAllocated,
            SUM(qtyOnOrder) AS totalOnOrder
        FROM
            qtyInventoryTotals
        WHERE locationGroupId IN (4)
        GROUP BY partId
    ) AS invORL ON invORL.partId = part.id
left join partreorder prORL on prORL.partid=part.id and prORL.locationgroupid=4


 LEFT JOIN (
        SELECT
            partId,
            SUM(qtyOnHand) AS totalOnHand,
            SUM(qtyNotAvailable) AS totalNotAvailable,
            SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
            SUM(qtyDropship) AS totalDropship,
            SUM(qtyAllocated) AS totalAllocated,
            SUM(qtyOnOrder) AS totalOnOrder
        FROM
            qtyInventoryTotals
        WHERE locationGroupId IN (8)
        GROUP BY partId
    ) AS invORLNew ON invORLNew.partId = part.id
left join partreorder prORLNew on prORLNew.partid=part.id and prORLNew.locationgroupid=8

   LEFT JOIN (
        SELECT
            partId,
            SUM(qtyOnHand) AS totalOnHand,
            SUM(qtyNotAvailable) AS totalNotAvailable,
            SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
            SUM(qtyDropship) AS totalDropship,
            SUM(qtyAllocated) AS totalAllocated,
            SUM(qtyOnOrder) AS totalOnOrder
        FROM
            qtyInventoryTotals
        WHERE locationGroupId IN (5)
        GROUP BY partId
    ) AS invNOLA ON invNOLA.partId = part.id
left join partreorder prNOLA on prNOLA.partid=part.id and prNOLA.locationgroupid=5

    LEFT JOIN (
        SELECT
            partId,
            SUM(qtyOnHand) AS totalOnHand,
            SUM(qtyNotAvailable) AS totalNotAvailable,
            SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
            SUM(qtyDropship) AS totalDropship,
            SUM(qtyAllocated) AS totalAllocated,
            SUM(qtyOnOrder) AS totalOnOrder
        FROM
            qtyInventoryTotals
        WHERE locationGroupId IN (6)
        GROUP BY partId
    ) AS invDC ON invDC.partId = part.id
left join partreorder prDC on prDC.partid=part.id and prDC.locationgroupid=6

LEFT JOIN (
        SELECT
            partId,
            SUM(qtyOnHand) AS totalOnHand,
            SUM(qtyNotAvailable) AS totalNotAvailable,
            SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
            SUM(qtyDropship) AS totalDropship,
            SUM(qtyAllocated) AS totalAllocated,
            SUM(qtyOnOrder) AS totalOnOrder
        FROM
            qtyInventoryTotals
        WHERE locationGroupId IN (7)
        GROUP BY partId
    ) AS invNSH ON invNSH.partId = part.id
left join partreorder prNSH on prNSH.partid=part.id and prNSH.locationgroupid=7

left join
(
SELECT SUM(soitem.qtyfulfilled) as last6,product.partid FROM so
INNER JOIN soitem ON so.id=soitem.soid

INNER JOIN product ON product.id=soitem.productid
WHERE so.locationgroupid  IN (1)
AND soitem.datelastfulfillment BETWEEN CAST(DATE_SUB(NOW(),INTERVAL 6 MONTH) AS DATE) AND CURRENT_DATE
AND  soitem.typeid IN (10,11,12,$P!{ckIncludeReturns},21,30,31,50,60,80)


GROUP BY product.partid
) as atxLast6 on atxLast6.partId = part.id

left join
(
SELECT SUM(soitem.qtyfulfilled) as last6,product.partid FROM so
INNER JOIN soitem ON so.id=soitem.soid

INNER JOIN product ON product.id=soitem.productid
WHERE so.locationgroupid  IN (10)
AND soitem.datelastfulfillment BETWEEN CAST(DATE_SUB(NOW(),INTERVAL 6 MONTH) AS DATE) AND CURRENT_DATE
AND  soitem.typeid IN (10,11,12,$P!{ckIncludeReturns},21,30,31,50,60,80)


GROUP BY product.partid
) as atxNewLast6 on atxNewLast6.partId = part.id

left join
(
SELECT SUM(soitem.qtyfulfilled) as last6,product.partid FROM so
INNER JOIN soitem ON so.id=soitem.soid

INNER JOIN product ON product.id=soitem.productid
WHERE so.locationgroupid  IN (9)
AND soitem.datelastfulfillment BETWEEN CAST(DATE_SUB(NOW(),INTERVAL 6 MONTH) AS DATE) AND CURRENT_DATE
AND  soitem.typeid IN (10,11,12,$P!{ckIncludeReturns},21,30,31,50,60,80)


GROUP BY product.partid
) as jaxLast6 on jaxLast6.partId = part.id

left join
(
SELECT SUM(soitem.qtyfulfilled) as last6,product.partid FROM so
INNER JOIN soitem ON so.id=soitem.soid

INNER JOIN product ON product.id=soitem.productid
WHERE so.locationgroupid  IN (3)
AND soitem.datelastfulfillment BETWEEN CAST(DATE_SUB(NOW(),INTERVAL 6 MONTH) AS DATE) AND CURRENT_DATE
AND  soitem.typeid IN (10,11,12,$P!{ckIncludeReturns},21,30,31,50,60,80)


GROUP BY product.partid
) as tpaLast6 on tpaLast6.partId = part.id

left join
(
SELECT SUM(soitem.qtyfulfilled) as last6,product.partid FROM so
INNER JOIN soitem ON so.id=soitem.soid

INNER JOIN product ON product.id=soitem.productid
WHERE so.locationgroupid  IN (4)
AND soitem.datelastfulfillment BETWEEN CAST(DATE_SUB(NOW(),INTERVAL 6 MONTH) AS DATE) AND CURRENT_DATE
AND  soitem.typeid IN (10,11,12,$P!{ckIncludeReturns},21,30,31,50,60,80)


GROUP BY product.partid
) as orlLast6 on orlLast6.partId = part.id

left join
(
SELECT SUM(soitem.qtyfulfilled) as last6,product.partid FROM so
INNER JOIN soitem ON so.id=soitem.soid

INNER JOIN product ON product.id=soitem.productid
WHERE so.locationgroupid  IN (8)
AND soitem.datelastfulfillment BETWEEN CAST(DATE_SUB(NOW(),INTERVAL 6 MONTH) AS DATE) AND CURRENT_DATE
AND  soitem.typeid IN (10,11,12,$P!{ckIncludeReturns},21,30,31,50,60,80)


GROUP BY product.partid
) as orlNewLast6 on orlNewLast6.partId = part.id

left join
(
SELECT SUM(soitem.qtyfulfilled) as last6,product.partid FROM so
INNER JOIN soitem ON so.id=soitem.soid

INNER JOIN product ON product.id=soitem.productid
WHERE so.locationgroupid  IN (5)
AND soitem.datelastfulfillment BETWEEN CAST(DATE_SUB(NOW(),INTERVAL 6 MONTH) AS DATE) AND CURRENT_DATE
AND  soitem.typeid IN (10,11,12,$P!{ckIncludeReturns},21,30,31,50,60,80)


GROUP BY product.partid
) as nolaLast6 on nolaLast6.partId = part.id

left join
(
SELECT SUM(soitem.qtyfulfilled) as last6,product.partid FROM so
INNER JOIN soitem ON so.id=soitem.soid

INNER JOIN product ON product.id=soitem.productid
WHERE so.locationgroupid  IN (6)
AND soitem.datelastfulfillment BETWEEN CAST(DATE_SUB(NOW(),INTERVAL 6 MONTH) AS DATE) AND CURRENT_DATE
AND  soitem.typeid IN (10,11,12,$P!{ckIncludeReturns},21,30,31,50,60,80)


GROUP BY product.partid
) as dcLast6 on dcLast6.partId = part.id


left join
(
SELECT SUM(soitem.qtyfulfilled) as last6,product.partid FROM so
INNER JOIN soitem ON so.id=soitem.soid

INNER JOIN product ON product.id=soitem.productid
WHERE so.locationgroupid  IN (7)
AND soitem.datelastfulfillment BETWEEN CAST(DATE_SUB(NOW(),INTERVAL 6 MONTH) AS DATE) AND CURRENT_DATE
AND  soitem.typeid IN (10,11,12,$P!{ckIncludeReturns},21,30,31,50,60,80)


GROUP BY product.partid
) as nshLast6 on nshLast6.partId = part.id
WHERE
    part.num LIKE $P{partNum}
    AND part.id != 0
    AND part.typeid = 10
    AND part.activeflag = 1

ORDER BY part.num]]>
		</queryString>
