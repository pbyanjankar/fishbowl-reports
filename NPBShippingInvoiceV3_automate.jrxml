	<queryString>
		<![CDATA[SELECT

PostSo.id AS POSTSOID,
ship.STATUSID,
SO.NUM AS SONUM,
SO.CUSTOMERPO,
TRIM(LEADING 'S' FROM ship.num) AS SHIPNUM
FROM ship
INNER JOIN ShipItem ON Ship.id = ShipItem.shipId
LEFT OUTER JOIN so ON ship.soid = so.id
LEFT JOIN PostSoItem ON PostSoItem.shipItemId = ShipItem.id
LEFT JOIN PostSo ON PostSo.id = PostSoItem.postSoId
WHERE ShipItem.shipId = $P{shipID}

LIMIT 1]]>
	</queryString>
	<field name="POSTSOID" class="java.lang.Integer"/>
	<field name="STATUSID" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="SHIPNUM" class="java.lang.String"/>
	<field name="CUSTOMERPO" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="SONUM" class="java.lang.String"/>
	<variable name="country" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("country", "US")]]></variableExpression>
	</variable>
	<variable name="ORDERNUMBER" class="java.lang.String">
		<variableExpression><![CDATA[$P{cbOrderNumber}.equals("Ship") ?
                    $F{SHIPNUM} :
                    ($P{cbOrderNumber}.equals("SO") ?
                        $F{SONUM} :
                        ($F{CUSTOMERPO} == null || $F{CUSTOMERPO}.length() < 1 ?
                           $F{SONUM} :
                           $F{CUSTOMERPO})
                   )]]></variableExpression>
	</variable>
