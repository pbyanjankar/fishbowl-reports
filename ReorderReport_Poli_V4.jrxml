		<queryString>
			<![CDATA[SELECT DISTINCT
    LOCATIONGROUP.NAME,
    PART.NUM AS PART,
    product.num AS PRODUCTNUMBER,
    UOM.CODE AS UOMCODE,
    COALESCE(LocLGQOH.qoh, 0) AS QTY,
    COALESCE(qtyAllocated.qty, 0) AS ALLOCATED,
    COALESCE(qtyonorder.qty, 0) AS ONORDER,
    COALESCE(qtynotavailable.qty,0) AS NOTAVAILABLE,
    COALESCE(qtyDropship.qty,0) AS DROPSHIP,
    PARTREORDER.REORDERPOINT AS REORDERPOINT,
    PARTREORDER.ORDERUPTOLEVEL AS ORDERUPTOLEVEL,
    PART.DESCRIPTION,
    VENDOR.NAME AS VENDOR,
    part.abccode,
    product.description AS PRODUCTDESCRIPTION,
    product.price AS PRODUCTPRICE,
    vendorparts.lastCost AS VENDORLASTCOST,
   (CASE
        WHEN (COALESCE(LocLGQOH.qoh, 0) - COALESCE(qtyAllocated.qty, 0) - COALESCE(qtynotavailable.qty,0) +  COALESCE(qtyDropship.qty,0))  > PARTREORDER.REORDERPOINT THEN '1-Good'
        WHEN (COALESCE(LocLGQOH.qoh, 0) - COALESCE(qtyAllocated.qty, 0) - COALESCE(qtynotavailable.qty,0) +  COALESCE(qtyDropship.qty,0)) > (PARTREORDER.REORDERPOINT/2) &&  (COALESCE(LocLGQOH.qoh, 0) - COALESCE(qtyAllocated.qty, 0) - COALESCE(qtynotavailable.qty,0) +  COALESCE(qtyDropship.qty,0)) <= PARTREORDER.REORDERPOINT THEN '2-Alert'
        WHEN (COALESCE(LocLGQOH.qoh, 0) - COALESCE(qtyAllocated.qty, 0) - COALESCE(qtynotavailable.qty,0) +  COALESCE(qtyDropship.qty,0)) <= (PARTREORDER.REORDERPOINT/2) THEN '3-Critical'
    END) as ALERTLEVEL,

if(coalesce(soldYTD.QtySold,0)<0, 0, coalesce(soldYTD.QtySold,0)) AS SALESQTYYTD,
if(coalesce(sold365.QtySold,0)<0, 0, coalesce(sold365.QtySold,0))  AS SALESQTY365,
CASE
   WHEN coalesce(period_diff(date_format(curdate(),"%Y%m"), date_format(oldsold.TIMEBEENFORSALE,"%Y%m")), 1) > 12 THEN 12
   WHEN coalesce(period_diff(date_format(curdate(),"%Y%m"), date_format(oldsold.TIMEBEENFORSALE,"%Y%m")), 1) < 1 THEN 1
   ELSE coalesce(period_diff(date_format(curdate(),"%Y%m"), date_format(oldsold.TIMEBEENFORSALE,"%Y%m")), 1)
END AS TIMEBEENFORSALE,
if(coalesce(soldYTD.QtySold,0)<0, 0, coalesce(soldYTD.QtySold,0))/month(CURDATE()) AS AVGYTD,

if(coalesce(sold365.QtySold,0)<0, 0, coalesce(sold365.QtySold,0)) /(CASE
   WHEN coalesce(period_diff(date_format(curdate(),"%Y%m"), date_format(oldsold.TIMEBEENFORSALE,"%Y%m")), 1) > 12 THEN 12
   WHEN coalesce(period_diff(date_format(curdate(),"%Y%m"), date_format(oldsold.TIMEBEENFORSALE,"%Y%m")), 1) < 1 THEN 1
   ELSE coalesce(period_diff(date_format(curdate(),"%Y%m"), date_format(oldsold.TIMEBEENFORSALE,"%Y%m")), 1)
END) AS AVG365,

    ProductTreePath.fullpath AS FULLPATH,
    producttree.name AS CATEGORY,
    parentProductTree.name AS PARENTCATEGORY,
    coalesce(ResultQtyFulfilled1.qtyFulfilled,0) AS QTYFULFILLED1,
    coalesce(ResultQtyFulfilled2.qtyFulfilled,0) AS QTYFULFILLED2,
    coalesce(ResultQtyFulfilled3.qtyFulfilled,0) AS QTYFULFILLED3,
    coalesce(ResultQtyFulfilled4.qtyFulfilled,0) AS QTYFULFILLED4,
    coalesce(ResultQtyFulfilled5.qtyFulfilled,0) AS QTYFULFILLED5,
    coalesce(ResultQtyFulfilled6.qtyFulfilled,0) AS QTYFULFILLED6
FROM part
    LEFT JOIN product ON product.partId = part.id
    LEFT JOIN locationgroup ON locationgroup.id IN ($P!{locationGroupID})
    LEFT JOIN partreorder ON locationgroup.id = partreorder.locationgroupid AND part.id = partreorder.partid
    LEFT JOIN uom ON part.uomid = uom.id
    LEFT JOIN qtyonhand ON (part.id = qtyonhand.partid AND locationgroup.id = qtyonhand.locationgroupid)
    LEFT JOIN qtyallocated ON (part.id = qtyallocated.partid AND locationgroup.id = qtyallocated.locationgroupid)
    LEFT JOIN qtyonorder ON (part.id = qtyonorder.partid AND locationgroup.id = qtyonorder.locationgroupid)
    LEFT JOIN qtynotavailable ON (part.id = qtynotavailable.partid AND locationgroup.id = qtynotavailable.locationgroupid)
    LEFT JOIN qtydropship ON (part.id = qtydropship.partid AND locationgroup.id = qtydropship.locationgroupid)
    LEFT JOIN vendorparts ON part.id = vendorparts.partid AND vendorparts.defaultflag = 1
    LEFT JOIN vendor ON vendorparts.vendorid = vendor.id

-- START OF SALES YTD

LEFT OUTER JOIN ( SELECT product.partid AS PartID,
		SUM(
		CASE WHEN soitem.typeid = 20
     		THEN -1 * ((soitem.qtyfulfilled  * COALESCE(UOMCONVERSION.MULTIPLY,1)) / COALESCE(UOMCONVERSION.FACTOR,1))
     		ELSE  ((soitem.qtyfulfilled * COALESCE(UOMCONVERSION.MULTIPLY,1)) / COALESCE(UOMCONVERSION.FACTOR,1))
		END) AS QtySold,
		so.locationgroupid AS LGID
                 FROM soitem
                 LEFT JOIN product ON soitem.productid = product.id
                 LEFT JOIN so ON so.id = soitem.soid
	       LEFT JOIN part ON product.partid = part.id
	       LEFT JOIN uomconversion ON (uomconversion.touomid = part.uomid AND uomconversion.fromuomid = soitem.uomid)
                WHERE soitem.qtyfulfilled > 0
                  AND soitem.datelastfulfillment BETWEEN MAKEDATE(EXTRACT(YEAR FROM CURDATE()),1) AND DATE_SUB(CURDATE(), INTERVAL 1 SECOND)
                GROUP BY product.partid, so.locationgroupid
) AS soldYTD ON part.id = soldYTD.partid AND locationgroup.id = soldYTD.lgid


-- END OF SALES YTD


-- START OF SALES 365 days to current day

LEFT OUTER JOIN ( SELECT product.partid AS PartID,
		SUM(
		CASE WHEN soitem.typeid = 20
     		THEN -1 * ((soitem.qtyfulfilled  * COALESCE(UOMCONVERSION.MULTIPLY,1)) / COALESCE(UOMCONVERSION.FACTOR,1))
     		ELSE  ((soitem.qtyfulfilled * COALESCE(UOMCONVERSION.MULTIPLY,1)) / COALESCE(UOMCONVERSION.FACTOR,1))
		END) AS QtySold,
		so.locationgroupid AS LGID
                 FROM soitem
                 LEFT JOIN product ON soitem.productid = product.id
                 LEFT JOIN so ON so.id = soitem.soid
	       LEFT JOIN part ON product.partid = part.id
	       LEFT JOIN uomconversion ON (uomconversion.touomid = part.uomid AND uomconversion.fromuomid = soitem.uomid)
                WHERE soitem.qtyfulfilled > 0
                  AND soitem.datelastfulfillment BETWEEN DATE_SUB(CURDATE(), INTERVAL 365 day) AND DATE_SUB(CURDATE(), INTERVAL 1 SECOND)
                GROUP BY product.partid, so.locationgroupid
) AS sold365 ON part.id = sold365.partid AND locationgroup.id = sold365.LGID


-- END OF SALES 365 days to current day

-- START OF TIME THE PRODUCT HAS BEEN SALE (First time the item is introduced)
LEFT OUTER JOIN
   ( SELECT partId, LGID, min(TIMEBEENFORSALE) AS TIMEBEENFORSALE FROM (SELECT
    part.id AS partId,
    endlocationgroup.id AS LGID,
    min(inventorylog.eventdate) AS TIMEBEENFORSALE
    FROM inventorylog
    	JOIN part ON part.id = inventorylog.partId
    	JOIN location beglocation ON inventorylog.beglocationid = beglocation.id
    	JOIN locationgroup beglocationgroup ON beglocation.locationgroupid = beglocationgroup.id
	JOIN location endlocation ON inventorylog.endlocationid = endlocation.id
	JOIN locationgroup endlocationgroup ON endlocation.locationgroupid = endlocationgroup.id
	WHERE inventorylog.typeid in (CASE WHEN inventorylog.typeid = 10 AND inventorylog.tableid IS NULL THEN 10 ELSE 0 END,
		         CASE WHEN inventorylog.typeid = 10 AND inventorylog.tableid = -1081854656 THEN 10 ELSE 0 END,
		         CASE WHEN inventorylog.typeid = 10 AND inventorylog.tableid = -355941248 THEN 10 ELSE 0 END,30,40,50,60,64,65,67,90)
and CASE
	WHEN inventorylog.typeid IN (30,40) AND beglocationgroup.id = endlocationgroup.id THEN 0
	ELSE inventorylog.changeqty
    END <> 0
    GROUP BY 1,2

   UNION

   SELECT part.id AS partId, locationGroup.id AS LGID, min(dateReceived) AS TIMEBEENFORSALE from receiptitem
      INNER JOIN part ON part.id = receiptitem.partid
      INNER JOIN location ON location.id = receiptitem.locationId
      INNER JOIN locationgroup ON locationgroup.Id = location.locationgroupid
      GROUP BY 1,2) AS result
      GROUP BY 1,2
) AS oldSold ON part.id = oldSold.partid AND locationgroup.id = oldSold.LGID

-- END OF TIME THE PRODUCT HAS BEEN SALE


-- Category
    LEFT JOIN ProductToTree ON product.id = producttotree.productid
    LEFT JOIN ProductTree ON producttotree.producttreeid = producttree.id
    LEFT JOIN producttree AS parentProductTree ON parentProductTree.id = producttree.parentId
    LEFT JOIN (
	SELECT
    		child.id AS child_id,
    		child.name AS child_name,
    		CONCAT(
     			if(root.name IS NULL, '', root.name + " > "),
        			if(parent7.name IS NULL, '', CONCAT(parent7.name,  " > ")),
       			if(parent6.name IS NULL, '', CONCAT(parent6.name,  " > ")),
        			if(parent5.name IS NULL, '', CONCAT(parent5.name,  " > ")),
        			if(parent4.name IS NULL, '', CONCAT(parent4.name,  " > ")),
       		          if(parent3.name IS NULL, '', CONCAT(parent3.name,  " > ")),
        			if(parent2.name IS NULL, '',  CONCAT(parent2.name, " > ")),
        			if(parent1.name IS NULL, '', CONCAT(parent1.name , " > ")),
			if(child.name IS NULL, '', CONCAT(child.name))
    		) AS fullpath
		FROM producttree AS child
		LEFT JOIN producttree AS parent1 ON child.parentId = parent1.id
		LEFT JOIN producttree AS parent2 ON parent1.parentId = parent2.id
		LEFT JOIN producttree AS parent3 ON parent2.parentId = parent3.id
		LEFT JOIN producttree AS parent4 ON parent3.parentId = parent4.id
		LEFT JOIN producttree AS parent5 ON parent4.parentId = parent5.id
		LEFT JOIN producttree AS parent6 ON parent5.parentId = parent6.id
		LEFT JOIN producttree AS parent7 ON parent6.parentId = parent7.id
		LEFT JOIN producttree AS root ON parent7.parentId = root.id
	WHERE child.parentId IS NOT NULL) AS ProductTreePath ON ProductTreePath.child_id = producttotree.producttreeid

-- END of Category


      LEFT OUTER JOIN (SELECT
        			sum(tag.qty) AS qoh,
        			locationgroup.id AS lgid,
        			tag.partId AS partId
   		 FROM
       			 tag
		 INNER JOIN location ON tag.locationId=location.id AND (location.activeFlag = true OR location.pickable=true OR location.countedAsAvailable=true)
		 INNER JOIN locationgroup ON location.locationgroupid = locationgroup.id
		 WHERE
			tag.typeId in (30 , 40)
        		GROUP BY locationgroup.id, tag.partid) AS LocLGQOH ON LocLGQOH.partid = part.id AND LocLGQOH.lgid = locationgroup.id


-- Qty Fulfilled for 6 date ranges
LEFT OUTER JOIN (
	SELECT
    		product.id AS productId,
    		locationgroup.id AS lgid,
    		SUM(soitem.qtyFulfilled) AS qtyFulfilled
	FROM soitem
   	 INNER JOIN product ON product.ID = soitem.productid
    	 INNER JOIN so ON so.id = soitem.soid
     	 INNER JOIN locationgroup ON locationgroup.id = so.locationgroupid
	WHERE soitem.qtyfulfilled > 0  AND soitem.datelastfulfillment BETWEEN $P{dateRange1QtyFulfilled1} AND DATE_SUB($P{dateRange2QtyFulfilled1}, INTERVAL 1 SECOND)
	GROUP BY 1,2
) AS ResultQtyFulfilled1 ON ResultQtyFulfilled1.productId = product.id AND ResultQtyFulfilled1.lgid = locationgroup.id

LEFT OUTER JOIN (
	SELECT
    		product.id AS productId,
    		locationgroup.id AS lgid,
    		SUM(soitem.qtyFulfilled) AS qtyFulfilled
	FROM soitem
   	 INNER JOIN product ON product.ID = soitem.productid
    	 INNER JOIN so ON so.id = soitem.soid
     	 INNER JOIN locationgroup ON locationgroup.id = so.locationgroupid
	WHERE soitem.qtyfulfilled > 0  AND soitem.datelastfulfillment BETWEEN $P{dateRange1QtyFulfilled2} AND DATE_SUB($P{dateRange2QtyFulfilled2}, INTERVAL 1 SECOND)
	GROUP BY 1,2
) AS ResultQtyFulfilled2 ON ResultQtyFulfilled2.productId = product.id AND ResultQtyFulfilled2.lgid = locationgroup.id

LEFT OUTER JOIN (
	SELECT
    		product.id AS productId,
    		locationgroup.id AS lgid,
    		SUM(soitem.qtyFulfilled) AS qtyFulfilled
	FROM soitem
   	 INNER JOIN product ON product.ID = soitem.productid
    	 INNER JOIN so ON so.id = soitem.soid
     	 INNER JOIN locationgroup ON locationgroup.id = so.locationgroupid
	WHERE soitem.qtyfulfilled > 0  AND soitem.datelastfulfillment BETWEEN $P{dateRange1QtyFulfilled3} AND DATE_SUB($P{dateRange2QtyFulfilled3}, INTERVAL 1 SECOND)
	GROUP BY 1,2
) AS ResultQtyFulfilled3 ON ResultQtyFulfilled3.productId = product.id AND ResultQtyFulfilled3.lgid = locationgroup.id

LEFT OUTER JOIN (
	SELECT
    		product.id AS productId,
    		locationgroup.id AS lgid,
    		SUM(soitem.qtyFulfilled) AS qtyFulfilled
	FROM soitem
   	 INNER JOIN product ON product.ID = soitem.productid
    	 INNER JOIN so ON so.id = soitem.soid
     	 INNER JOIN locationgroup ON locationgroup.id = so.locationgroupid
	WHERE soitem.qtyfulfilled > 0  AND soitem.datelastfulfillment BETWEEN $P{dateRange1QtyFulfilled4} AND DATE_SUB($P{dateRange2QtyFulfilled4}, INTERVAL 1 SECOND)
	GROUP BY 1,2
) AS ResultQtyFulfilled4 ON ResultQtyFulfilled4.productId = product.id AND ResultQtyFulfilled4.lgid = locationgroup.id


LEFT OUTER JOIN (
	SELECT
    		product.id AS productId,
    		locationgroup.id AS lgid,
    		SUM(soitem.qtyFulfilled) AS qtyFulfilled
	FROM soitem
   	 INNER JOIN product ON product.ID = soitem.productid
    	 INNER JOIN so ON so.id = soitem.soid
     	 INNER JOIN locationgroup ON locationgroup.id = so.locationgroupid
	WHERE soitem.qtyfulfilled > 0  AND soitem.datelastfulfillment BETWEEN $P{dateRange1QtyFulfilled5} AND DATE_SUB($P{dateRange2QtyFulfilled5}, INTERVAL 1 SECOND)
	GROUP BY 1,2
) AS ResultQtyFulfilled5 ON ResultQtyFulfilled5.productId = product.id AND ResultQtyFulfilled5.lgid = locationgroup.id

LEFT OUTER JOIN (
	SELECT
    		product.id AS productId,
    		locationgroup.id AS lgid,
    		SUM(soitem.qtyFulfilled) AS qtyFulfilled
	FROM soitem
   	 INNER JOIN product ON product.ID = soitem.productid
    	 INNER JOIN so ON so.id = soitem.soid
     	 INNER JOIN locationgroup ON locationgroup.id = so.locationgroupid
	WHERE soitem.qtyfulfilled > 0  AND soitem.datelastfulfillment BETWEEN $P{dateRange1QtyFulfilled6} AND DATE_SUB($P{dateRange2QtyFulfilled6}, INTERVAL 1 SECOND)
	GROUP BY 1,2
) AS ResultQtyFulfilled6 ON ResultQtyFulfilled6.productId = product.id AND ResultQtyFulfilled6.lgid = locationgroup.id

WHERE part.id != 0
  AND part.num LIKE $P{partNum}
  AND part.activeflag IN (1,$P!{ckShowInactiveParts})
  AND if($P{ShowEntireProductList}, true, ((COALESCE(producttreeid,0) IN ($P!{productTree1})) OR ((COALESCE(producttreeid,0) LIKE $P{productTree2}))))
  AND (partreorder.locationgroupid IN ($P!{locationGroupID}) OR partreorder.locationgroupid IS NULL)
  AND if($P{ShowDiscontinued}, true, coalesce(CustomFieldByName(part.customFields, 'Discontinued'),'false') = 'false')

ORDER BY LOCATIONGROUP.NAME, $P!{cbOrderBy} $P!{cbSortOrder}, product.num;]]>
		</queryString>
