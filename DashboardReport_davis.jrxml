	</parameter>
	<parameter name="soNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="ckIncludeShipping" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[60,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckShowSOStatusClosedShort" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[70,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["70"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckShowSOStatusFulfilled" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[60,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["60"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckShowSOStatusInProgress" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[25,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckIncludeReturns" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[20,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckIncludeDiscounts" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[3,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["3"]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportTitle" class="java.lang.String" isForPrompting="false"/>
	<parameter name="salesPersonDefaultSalesperson" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportOnDate" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[Today]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
distinct
cogsReport.*,
quotes.NUMBEROFQUOTES,
issued.NUMBEROFISSUED
FROM customer
INNER JOIN sysuser ON sysuser.id = customer.defaultsalesmanid
LEFT OUTER JOIN
(SELECT
defaultsalesmanid,
DEFAULTSALESPERSON,
company,
symbol,
sum(cogs) as cogs,
sum(price) as price,
sum(price) - sum(cogs) as grossmargins
FROM
(SELECT

-- All status Discount, Misc Credit, Return and Shipping items
defaultsalesman.id AS defaultsalesmanid,
defaultsalesman.username AS DEFAULTSALESPERSON,
soitem.datelastfulfillment AS datecompleted,
company.name AS company,
currency.symbol,
sum(soitem.totalcost) AS cogs,
sum(IF(soitem.typeid = 21, soitem.totalprice, postsoitem.totalprice)) AS price,
sum(IF(soitem.typeid = 21, soitem.totalprice, postsoitem.totalprice))-sum((IF(soitem.typeid = 21, soitem.qtytofulfill, postsoitem.qty) * (soitem.totalcost / soitem.qtytofulfill))) AS grossmargins

FROM so
    INNER JOIN soitem ON so.id = soitem.soid
    LEFT JOIN postsoitem ON soitem.id = postsoitem.soitemid
    JOIN company ON company.id = 1
    LEFT JOIN customer on so.customerid = customer.id
    LEFT JOIN currency ON currency.homeCurrency = 1
    LEFT OUTER JOIN sysuser defaultsalesman ON defaultsalesman.id = customer.defaultsalesmanid

WHERE
  UPPER(COALESCE(defaultsalesman.username,"")) LIKE UPPER($P{salesPersonDefaultSalesperson})
  AND COALESCE(soitem.datelastfulfillment,so.dateLastModified) BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
  AND soitem.typeid IN (21,$P!{ckIncludeDiscounts}0,$P!{ckIncludeDiscounts}1,$P!{ckIncludeReturns},$P{ckIncludeShipping})
  AND so.statusid IN ($P{ckShowSOStatusFulfilled},$P{ckShowSOStatusClosedShort})
  AND soitem.qtyToFulFill > 0

GROUP BY 1,2,3,4, 5

UNION ALL

-- SHIPPED Sales, Assoc. Price, and Kit items

SELECT
 defaultsalesman.id AS defaultsalesmanid,
    defaultsalesman.username AS DEFAULTSALESPERSON,
so.datecompleted AS DATECOMPLETED,
    company.name AS company,
    currency.symbol,

    postsoitem.postedtotalcost as posttotal,
    ((soitem.unitprice + (CASE WHEN soitem.adjustamount > 0 THEN (soitem.adjustamount / soitem.qtytofulfill) ELSE 0 END)) * postsoitem.qty),
    ((soitem.unitprice + (CASE WHEN soitem.adjustamount > 0 THEN (soitem.adjustamount / soitem.qtytofulfill) ELSE 0 END)) * postsoitem.qty) - postsoitem.postedtotalcost



FROM so
    INNER JOIN soitem ON so.id = soitem.soid
    LEFT JOIN postsoitem ON soitem.id = postsoitem.soitemid
    LEFT JOIN postso ON postsoitem.postsoid = postso.id
    JOIN company ON company.id = 1
    LEFT JOIN customer on so.customerid = customer.id
    LEFT JOIN currency ON currency.homeCurrency = 1
 LEFT OUTER JOIN sysuser defaultsalesman ON defaultsalesman.id = customer.defaultsalesmanid


WHERE UPPER(COALESCE(defaultsalesman.username,"")) LIKE UPPER($P{salesPersonDefaultSalesperson})
  AND postso.postdate BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
  AND soitem.typeid IN (10,11,12,50,$P!{ckIncludeReturns},80)
  AND SO.statusID IN ($P{ckShowSOStatusFulfilled},$P{ckShowSOStatusClosedShort})
  AND soitem.qtyToFulFill > 0

GROUP BY 1,2,3,4, 5

) AS report

GROUP BY 1,2,3,4 ) cogsReport ON cogsReport.defaultsalesmanid = sysuser.id

-- Quotes
LEFT OUTER JOIN
(SELECT
	customer.defaultsalesmanid,
	count(*) AS NUMBEROFQUOTES
	FROM so
	INNER JOIN customer ON customer.id = so.customerid
	INNER JOIN (
		SELECT so_aud.id, so_aud.statusid, min(timestamp) AS dateEstimate  FROM so_aud
		INNER JOIN revinfo ON revinfo.id = so_aud.rev
		WHERE so_aud.statusId = 10
		GROUP BY so_aud.id, so_aud.statusid) AS result ON result.id = so.id
	GROUP BY customer.defaultsalesmanid) AS quotes ON quotes.defaultsalesmanid = sysuser.id

-- Issued
LEFT OUTER JOIN
(SELECT
	customer.defaultsalesmanid,
	sum(if(dateIssued IS NOT NULL, 1, 0)) AS NUMBEROFISSUED
	FROM so
	INNER JOIN customer ON customer.id = so.customerid
	GROUP BY customer.defaultsalesmanid) AS issued ON issued.defaultsalesmanid = sysuser.id
ORDER BY 1,2;]]>
	</queryString>
	<field name="COGS" class="java.lang.Double"/>
	<field name="PRICE" class="java.lang.Double"/>
	<field name="GROSSMARGINS" class="java.lang.Double"/>
	<field name="COMPANY" class="java.lang.String"/>
	<field name="SYMBOL" class="java.lang.Integer"/>
	<field name="DEFAULTSALESPERSON" class="java.lang.String"/>
	<field name="NUMBEROFQUOTES" class="java.lang.Double"/>
	<field name="NUMBEROFISSUED" class="java.lang.Double"/>
	<variable name="PriceDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
	</variable>
	<variable name="QtyDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
	</variable>
	<variable name="CostDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
	</variable>
	<variable name="DateFormat" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
	</variable>
	<variable name="isMultiCurrency" class="java.lang.Boolean">
		<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
	</variable>
