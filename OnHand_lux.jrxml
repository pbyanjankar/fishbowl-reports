			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="LOCATIONGROUP" class="java.lang.String"/>
		<field name="TRACKING" class="java.lang.String"/>
		<field name="ABCCODE" class="java.lang.String">
			<fieldDescription><![CDATA[]]></fieldDescription>
		</field>
		<field name="partcf1" class="java.lang.String"/>
