		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="Available" class="java.lang.Double" resetType="None">
			<variableExpression><![CDATA[new Double($F{QTY}.doubleValue() - $F{ALLOCATED}.doubleValue() - $F{NOTAVAILABLE}.doubleValue() + $F{DROPSHIP}.doubleValue())]]></variableExpression>
		</variable>
		<variable name="Needed" class="java.lang.Double" resetType="None">
			<variableExpression><![CDATA[($F{QTY}.doubleValue() + $F{ONORDER}.doubleValue() - $F{ALLOCATED}.doubleValue()- $F{NOTAVAILABLE}) <= $F{REORDERPOINT}.doubleValue() ?
($F{QTY}.doubleValue() + $F{ONORDER}.doubleValue() - $F{ALLOCATED}.doubleValue()-$F{NOTAVAILABLE}) <= $F{ORDERUPTOLEVEL}.doubleValue() ?
    new Double($F{ORDERUPTOLEVEL}.doubleValue() - ($F{QTY}.doubleValue() + $F{ONORDER}.doubleValue() - $F{ALLOCATED}.doubleValue()-$F{NOTAVAILABLE})) :
    new Double(0)
: new Double(0)]]></variableExpression>
		</variable>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="maxAvg" class="java.lang.Double" resetType="None">
			<variableExpression><![CDATA[$F{AVG365}>$F{AVGYTD}?$F{AVG365}:$F{AVGYTD}]]></variableExpression>
		</variable>
