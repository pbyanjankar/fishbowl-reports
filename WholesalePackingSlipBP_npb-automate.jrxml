	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["../Picking/"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Customized Report of Pick Report for Sales Orders - A complete list of ALL items on the Pick with pick item status in Entered, Entered New and Committed."]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRangeNone" class="java.lang.String" isForPrompting="false"/>
	<parameter name="ShowBarcode" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<parameter name="ReportTitle" class="java.lang.String" isForPrompting="false"/>
	<parameter name="cbLogoAlignment" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[top,Top,left,Left]]></parameterDescription>
		<defaultValueExpression><![CDATA["left"]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowCompanyName" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<parameter name="BlindShipment" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowCountry" class="java.lang.Boolean" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Boolean(false)]]></defaultValueExpression>
	</parameter>
	<parameter name="cbContactToShow" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[address,Address Name,contact,SO Contact]]></parameterDescription>
		<defaultValueExpression><![CDATA["address"]]></defaultValueExpression>
	</parameter>
	<parameter name="ShowMemos" class="java.lang.Boolean" isForPrompting="false">
		<property name="Group" value="Other Settings"/>
		<property name="Tooltip" value="Choose to show memos by checking this box."/>
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Boolean(false)]]></defaultValueExpression>
	</parameter>
	<parameter name="shipID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
PostSo.id AS POSTSOID,
COMPANY.NAME AS COMPANY,
SO.ID AS SOID,
SO.NUM AS SONUM,
SO.CUSTOMERCONTACT AS SHIPTOCONTACT,
SO.CUSTOMERPO AS SOCUSTOMERPO,
SO.BILLTOADDRESS,
SHIPNUMTABLE.SHIPTOADDRESS,
    SO.BILLTONAME,
SHIPNUMTABLE.SHIPTONAME,
 SO.BILLTOCITY,
SHIPNUMTABLE.SHIPTOCITY,
 BILLSTATE.NAME AS BILLTOSTATE,
SHIPNUMTABLE.SHIPTOSTATE,
    SO.BILLTOZIP,
 SHIPNUMTABLE.SHIPTOZIP,
BILLCOUNTRY.NAME AS BILLCOUNTRY,
SHIPNUMTABLE.SHIPCOUNTRY,
TRIM(LEADING 'S' FROM SHIPNUMTABLE.SHIPNUM) AS SHIPNUM,
    SO.LOCATIONGROUPID, COALESCE(SO.NOTE, '') AS SONOTE,
SO.CUSTOMERID, CAST(SHIPNUMTABLE.DATESHIPPED AS DATE) AS DATESHIPPED,
    SO.CURRENCYRATE,
CURRENCY.CODE AS CURRENCYCODE,
 CURRENCY.SYMBOL AS SYMBOL,
    SUM(postsoitem.totalprice) AS SUBTOTAL,
    SUM((CASE SOITEM.TAXABLEFLAG WHEN 1 THEN SO.TAXRATE ELSE 0 END) * POSTSOITEM.TOTALPRICE) AS TAXRATE,
    SUM((CASE SOITEM.TAXABLEFLAG
            WHEN 1
            THEN POSTSOITEM.TOTALPRICE * COALESCE(SO.TAXRATE, 0) / SO.CURRENCYRATE
            ELSE 0.0
        END)) AS CURRENCYTAXTOTAL,
    SUM((postsoitem.totalprice) / SO.CURRENCYRATE) AS CURRENCYSUBTOTAL,
    SUM(((postsoitem.totalprice) / SO.CURRENCYRATE)
        + ((CASE SOITEM.TAXABLEFLAG WHEN 1 THEN SO.TAXRATE ELSE 0 END) * (postsoitem.totalprice)) / SO.CURRENCYRATE) AS CURRENCYGRANDTOTAL,
HOMECURRENCY.SYMBOL AS HOMECURRENCYSYMBOL,
HOMECURRENCY.CODE AS HOMECURRENCYCODE,
ship.id AS SHIPID,
 so.phone,
so.email AS EMAIL,
COALESCE(currency.symbol,homecurrency.symbol,91) AS coalesceSymbol,
paymentterms.typeid as paymenttermtypeid,
DATE_ADD(ShipNumTable.dateShipped, INTERVAL coalesce(paymentterms.netdays, 0) day) AS paymentduedate,
paymentterms.netdays as paymenttermnetdays,
SHIPTERMS.NAME AS SHIPPINGTERMS,
carrierservice.name AS carrierservice,
paymentterms.name as PAYMENTTERMNAME,
    CARRIER.NAME AS CARRIERNAME,
priority.name AS priorityname
FROM PostSo
    INNER JOIN PostSoItem ON PostSo.id = PostSoItem.postSoId
    LEFT JOIN ShipItem ON PostSoItem.shipItemId = ShipItem.id
    LEFT JOIN Ship ON ShipItem.shipId = Ship.id
    INNER JOIN SoItem ON PostSoItem.soItemId = SoItem.id
    INNER JOIN So ON SoItem.soId = So.id AND PostSo.soId = So.id
    LEFT JOIN paymentterms ON paymentterms.id = so.paymenttermsid
    LEFT JOIN shipterms ON so.shiptermsid = shipterms.id
    LEFT JOIN carrier ON ship.carrierId = carrier.id
    INNER JOIN Customer ON So.customerId = Customer.id
    LEFT JOIN StateConst BillState ON So.billToStateId = BillState.id
    LEFT JOIN CountryConst BillCountry ON So.billToCountryId = BillCountry.id
    LEFT JOIN Currency ON Customer.currencyId = Currency.id
    LEFT JOIN carrierservice ON ship.carrierserviceid = carrierservice.id
    LEFT JOIN priority ON priority.id = so.priorityid
    INNER JOIN Company ON Company.id = 1
    INNER JOIN (SELECT PostSo.id AS postSoId, Ship.num AS shipNum, Ship.dateShipped AS dateShipped, SHIP.SHIPTOADDRESS,
    SHIP.SHIPTONAME, SHIP.SHIPTOCITY, SHIPSTATE.NAME AS SHIPTOSTATE,
    SHIP.SHIPTOZIP, SHIPCOUNTRY.NAME AS SHIPCOUNTRY
                FROM PostSo
                INNER JOIN PostSoItem ON PostSo.id = PostSoItem.postSoId
                INNER JOIN ShipItem ON PostSoItem.shipItemId = ShipItem.id
                INNER JOIN Ship ON ShipItem.shipId = Ship.id
                LEFT JOIN stateconst shipstate ON ship.shiptostateid = shipstate.id
                LEFT JOIN countryconst shipcountry ON shipcountry.id = ship.shiptocountryid
                WHERE ShipItem.shipId = $P{shipID} LIMIT 1) AS ShipNumTable ON PostSo.id = ShipNumTable.postSoId
    LEFT JOIN Currency AS HomeCurrency ON HomeCurrency.homeCurrency = 1

WHERE ShipItem.shipId = $P{shipID}
  AND SoItem.typeId != 40

GROUP BY PostSo.id, Company.name, So.id, So.num, So.customerContact, So.customerPo, So.billToAddress,
    So.billToName, So.billToCity, shipnumtable.shiptocity, BillState.name,
    So.billToZip,  shipnumtable.shiptozip, BillCountry.name,  shipnumtable.shipcountry, ShipNumTable.shipNum,
    So.locationGroupId, So.note, So.customerId, ShipNumTable.dateShipped,
    So.currencyRate, Currency.code, Currency.symbol, Company.id, So.taxRate, HomeCurrency.symbol, HomeCurrency.code,
paymentterms.netdays,
SHIPTERMS.NAME,
carrierservice.name,
paymentterms.name,
    CARRIER.NAME,
priority.name

ORDER BY COALESCE(ship.shiptoname, 'ZZZZ')]]>
	</queryString>
