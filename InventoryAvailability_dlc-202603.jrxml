(($F{TPAQTY} - $F{TPAALLOCATED} - $F{TPAUNAVAILABLE} + $F{TPADROPSHIP}) > 0 ?
    $F{TPAQTY} - $F{TPAALLOCATED} - $F{TPAUNAVAILABLE} + $F{TPADROPSHIP} :
