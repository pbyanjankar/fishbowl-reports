	<queryString>
		<![CDATA[SELECT DISTINCT so.note, so.id AS recordID,
    /* Customer info */
    so.customercontact, so.customerpo, so.customerid, customer.name AS customerName,
    /* Non-Currency */
    so.totalTax AS totaltax,

    /* Country version */
    COALESCE(UPPER(sysProperties.sysValue), 'US') AS qbVersion,
    /* Ship To */
    so.shiptoname, so.shiptoaddress, so.shiptocity, so.shiptozip,
    shipstate.code AS shiptostate, shipcountry.name AS shiptocountry,
    /* Bill To */
    so.billtoname AS billToName, so.billtoaddress, so.billtocity, so.billtozip,
    billstate.code AS billtostate, billcountry.name AS billtocountry,
    /* Currency */
    so.currencyRate, currency.code AS currencyCode, currency.symbol,

    SUM(soitem.unitPrice * soItem.qtyToFulfill + COALESCE(soItem.adjustAmount, 0)) AS totalprice,
    SUM(ROUND(soitem.unitPrice * soItem.qtyToFulfill + COALESCE(soItem.adjustAmount, 0), 2)) AS roundedTotalPrice,

    COALESCE(so.mcTotalTax, 0) AS currencyTaxTotal,

    CASE COALESCE(UPPER(sysProperties.sysValue), 'US')
        WHEN 'US' THEN SUM(Round((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate), 2))
        WHEN 'CA' THEN SUM(Round((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate), 2))
        WHEN 'AU' THEN SUM(Round((soItem.unitPrice * soItem.qtyToFulfill + soItem.adjustAmount) / so.currencyRate, 2))
        ELSE 0.0 END AS currencySubtotal,

    CASE COALESCE(UPPER(sysProperties.sysValue), 'US')
        WHEN 'US' THEN SUM((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate))
        WHEN 'CA' THEN SUM((soItem.unitPrice * soItem.qtyToFulfill / so.currencyRate) + (COALESCE(soItem.adjustAmount, 0) / so.currencyRate))
        WHEN 'AU' THEN SUM((soItem.unitPrice * soItem.qtyToFulfill + soItem.adjustAmount) / so.currencyRate)
        ELSE 0.0 END AS currencySubtotalNotRounded,

    /* AU ABN */
    company.ABN,
    /* Payment Info*/
    COALESCE(paymentInfo.amount,0) AS paymentAmount, so.currencyRate,
    COALESCE(paymentInfo.amount,0)/COALESCE(so.currencyRate, 1) AS currencyPaymentAmount, homeCurrency.symbol AS homeCurrencySymbol, COALESCE(contact.datus,'') AS fax, so.phone, so.email,

sototal.subtotal as SUBTOTAL,
customfieldbyname(customer.customfields, "Custom Sales Order Notes") as customernote,
so.salesman

FROM so
    INNER JOIN customer ON so.customerid = customer.id
    INNER JOIN company ON company.id = 1
    LEFT OUTER JOIN soitem ON so.id = soitem.soid AND soitem.typeid != 40
    LEFT OUTER JOIN countryconst billcountry ON billcountry.id = so.billtocountryid
    LEFT OUTER JOIN countryconst shipcountry ON shipcountry.id = so.shiptocountryid
    LEFT OUTER JOIN stateconst shipState ON so.shiptostateid = shipState.id
    LEFT OUTER JOIN stateconst billState ON so.billtostateid = billState.id
    LEFT OUTER JOIN sysProperties ON sysProperties.sysKey = 'QBVersion'
    LEFT OUTER JOIN currency ON customer.currencyId = currency.id
    LEFT OUTER JOIN currency AS homeCurrency ON homeCurrency.homeCurrency = 1
    LEFT OUTER JOIN (SELECT DISTINCT SUM(posTransaction.amount) AS amount, posTransaction.soId
                     FROM posTransaction
	 	GROUP BY posTransaction.soId) AS paymentInfo ON so.id = paymentInfo.soId
    LEFT JOIN (SELECT contact.datus, so.id AS soid
			FROM contact
			JOIN so ON so.num = $P{soNum}
			JOIN customer ON contact.accountid = customer.accountid AND customer.id = so.customerid
			WHERE contact.typeid = 40 AND contact.defaultflag = 1
			LIMIT 1) AS contact ON contact.soid = so.id
    inner join (select sum(soitem.unitprice*soitem.qtytofulfill) as subtotal, soitem.soid
                  from soitem
                   where soitem.typeid NOT IN (40,50,70)
                   group by soid) sototal on sototal.soid = so.id


WHERE so.num = $P{soNum}

GROUP BY so.note, so.customercontact, so.customerpo, so.customerid, so.id, so.totaltax,
    so.shiptoname, so.shiptoaddress, so.shiptocity, so.shiptozip,
    shipstate.code, shipcountry.name,
    so.billtoname, so.billtoaddress, so.billtocity, so.billtozip,
    billstate.code, billcountry.name, customer.name, currency.code, currency.symbol, so.currencyRate, sysProperties.sysValue,
    /* CA and AU */
    company.ABN, so.mcTotalTax, paymentInfo.amount, so.currencyRate, homeCurrency.symbol, fax, so.phone, so.email, customernote,sototal.subtotal, so.salesman]]>
	</queryString>
