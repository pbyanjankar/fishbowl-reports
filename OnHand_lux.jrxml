		<parameter name="productNum" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT
PART.NUM AS PARTNUM,
product.num AS PRODUCTNUMBER,
product.description AS PRODUCTDESC,
TAG.PARTID AS PARTID,
TAG.LOCATIONID AS LOCATIONID,
TAG.TRACKINGENCODING AS TRACKINGENCODING,
PART.DESCRIPTION AS PARTDESC,
PART.SERIALIZEDFLAG,
uom.code AS PARTUOM,
COALESCE(tag.TAGQTY,0) AS TAGQTY,
COALESCE(location.name, '') AS LOCATION,
COALESCE(locationgroup.name, '') AS LOCATIONGROUP,
GROUP_CONCAT(CONCAT('<b>' , tagtrackingview.abbr , ':</b> ' , tagtrackingview.infoformatted), '<br/>' ORDER BY tagtrackingview.abbr) AS TRACKING,
part.ABCCODE,
$P!{CustomField:Part1} AS partcf1,
$P!{CustomField:Part2} AS partcf2,
$P!{CustomField:Part3} AS partcf3
FROM part
     INNER JOIN product ON product.partId = part.id
     LEFT JOIN locationgroup ON 1=1
     LEFT JOIN uom ON part.uomid = uom.id
     $P!{ckShowPartsWithZeroQuantity} JOIN (
	SELECT MAX(tag.id) AS id, COALESCE(SUM(qty), 0) AS tagQty, partID, locationID, trackingEncoding, locationgroupid
	FROM Tag
          LEFT OUTER JOIN location ON tag.locationid = location.id
	GROUP BY trackingEncoding, partID, locationID
	) as Tag ON part.id = tag.partid AND tag.locationgroupid = locationgroup.id
     LEFT JOIN location ON tag.locationid = location.id
     LEFT JOIN tagtrackingview ON tagtrackingview.tagid = tag.id AND tagTrackingView.typeID <> 40

WHERE part.typeid = 10
  AND (tagtrackingview.typeid != 40 OR tagtrackingview.typeid IS NULL)
  AND COALESCE(part.trackingflag, 0) IN (1,$P!{ckShowPartsWithoutTracking})
  AND part.num LIKE $P{partNum}
  AND product.num LIKE $P{productNum}
  AND (location.id LIKE $P{locationID} OR location.name IS NULL)
  AND (locationgroup.id IN ($P!{locationGroupID}) OR locationgroup.id IS NULL)
  AND COALESCE(UPPER($P!{cfFilter}),'') LIKE UPPER($P{cfFilterData})

GROUP BY part.num, tag.partID, tag.locationID, tag.trackingEncoding, part.description, part.serializedflag,
    uom.code, tag.trackingEncoding, location.name, locationgroup.name, tagQty

HAVING UPPER(COALESCE(GROUP_CONCAT(CONCAT(tagtrackingview.abbr , ': ' , (CASE
                                                    WHEN tagtrackingview.TYPEID IN (20,30) THEN SUBSTRING(tagtrackingview.info FROM 1 FOR 10)
                                                    ELSE tagtrackingview.info
                                                   END))), '')) LIKE UPPER(CONCAT('%' , $P{Tracking} , '%'))

ORDER BY LocationGroup, UPPER($P!{cbOrderBy}), UPPER(part.num)]]>
		</queryString>
