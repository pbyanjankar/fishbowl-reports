	<subDataset name="Dataset_Remaining" uuid="8589364b-62c6-4141-bc7d-7b898b321be1">
		<parameter name="shipID" class="java.lang.String">
			<defaultValueExpression><![CDATA["7"]]></defaultValueExpression>
		</parameter>
		<parameter name="module" class="java.lang.Object" isForPrompting="false">
			<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
		</parameter>
		<parameter name="soId" class="java.lang.Integer"/>
		<parameter name="postSoId" class="java.lang.Integer"/>
		<queryString>
			<![CDATA[SELECT * FROM (select
DISTINCT
SoItem.soLineItem AS SOLINEITEM,
SoItemUom.code AS uomCode,
soitemtype.name as SOITEMTYPE,
SoItem.typeId AS SOITEMTYPEID,
product.num as PRODUCTNUMBER,
part.typeid AS PARTTYPEID,
SoItem.productnum AS SOITEMPRODUCTNUMBER,
ObjectToObject.recordId2 AS kitParentLine,
product.description as PRODUCTDESCRIPTION,
SoItem.description as SOITEMDESCRIPTION,
-- POSTTOTALPRICE is used for only Discounts, Shipping, Customer Deposits only
if(soitem.typeid=10 AND part.typeId=10, null, PostSoItem.totalPrice) AS POSTTOTALPRICE,
qtyOrdered AS QTYORDERED,
(CASE
	WHEN soitemtype.name = "KIT" THEN
		coalesce(KitProductQtyShipped,0)
	ELSE
		coalesce(shippedItems.qtyShipped,0)
END) AS QTYSHIPPED,
qtyordered - coalesce(totalshipped, 0) as QTYREMAINING,
soitem.unitPrice + (soitem.adjustAmount/soitem.qtyToFulfill) AS UNITPRICE,
(CASE
	WHEN soitemtype.name = "KIT" THEN
		coalesce(KitProductQtyShipped,0)
	ELSE
		coalesce(shippedItems.qtyShipped,0)
END) * (soitem.unitPrice + (soitem.adjustAmount/soitem.qtyToFulfill)) AS ExtendedPrice
from
soitem
LEFT JOIN ( SELECT soitem.id AS soitemid, coalesce(sum(shipitem.qtyShipped), 0) AS qtyShipped
	 FROM shipitem
	 INNER JOIN soitem ON shipitem.soItemId = soitem.id and shipid = $P{shipID}
	 GROUP BY soitem.id
) AS shippedItems ON shippedItems.soitemid = soitem.id
LEFT JOIN (
	SELECT recordId2, min(qtyshipped) AS KitProductQtyShipped FROM shipitem
	INNER JOIN ObjectToObject ON ObjectToObject.typeId = 30 AND  recordId1 = shipitem.soitemid
	WHERE shipid = $P{shipID}
	GROUP BY recordId2
) AS kitproductshipping ON kitproductshipping.recordId2 = soitem.id
left join
(
select soitemid as soitemid,recordId2 as KitParentId, sum(qtyshipped) as totalshipped from shipitem
LEFT JOIN ObjectToObject ON ObjectToObject.typeId =30 AND recordid1 = shipitem.soitemid
where
shipid in
 (select ship.id from ship
 INNER JOIN so on so.id = ship.soid
where so.id = $P{soId} and shipid <=  $P{shipID})
group by soitemid, KitParentId
UNION ALL
select KitParentId, "" as Child, min(totalshipped)  as totalshipped from (
select ObjectToObject.recordId1, ObjectToObject.recordId2 as KitParentId, sum(qtyshipped) as totalshipped from shipitem
LEFT JOIN ObjectToObject ON ObjectToObject.typeId =30 AND recordid1 = shipitem.soitemid
where ObjectToObject.recordId2 is not null AND
shipid in
 (select ship.id from ship
 INNER JOIN so on so.id = ship.soid
where so.id = $P{soId} and shipid <=  $P{shipID})
group by ObjectToObject.recordId1, KitParentId) as t2
group by KitParentId
) AS t
on soitem.id = t.soitemid
LEFT JOIN product on product.id = soitem.productId
LEFT JOIN part ON part.id = product.partId
INNER JOIN SoItemType ON SoItem.typeId = SoItemType.id AND soitem.typeid != 40
INNER JOIN Uom AS SoItemUom ON soitem.uomId = SoItemUom.id
LEFT JOIN postsoitem on postsoitem.soitemid = soitem.id and postsoitem.postsoid = $P{postSoId}
LEFT OUTER JOIN ObjectToObject ON ObjectToObject.typeId = 30 AND SoItem.id = ObjectToObject.recordId1
where
soitemtype.id IN (10,11,80) AND
((soitem.soid =$P{soId} and soitemtype.name <> "Shipping" and ObjectToObject.recordId2 is null)
OR
(soitem.soid =$P{soId} and soitemtype.name = "Shipping" and postsoitem.postsoid = $P{postSoId}))
) AS result
WHERE result.QTYREMAINING>0
ORDER BY result.SOLINEITEM;]]>
		</queryString>
		<field name="SOITEMTYPE" class="java.lang.String"/>
		<field name="UNITPRICE" class="java.lang.Double"/>
		<field name="EXTENDEDPRICE" class="java.lang.Double"/>
		<field name="PRODUCTDESCRIPTION" class="java.lang.String"/>
		<field name="QTYSHIPPED" class="java.lang.Double"/>
		<field name="QTYREMAINING" class="java.lang.Double"/>
		<field name="QTYORDERED" class="java.lang.Double"/>
		<field name="PRODUCTNUMBER" class="java.lang.String"/>
		<field name="UOMCODE" class="java.lang.String"/>
		<field name="SOITEMDESCRIPTION" class="java.lang.String"/>
		<field name="SOITEMPRODUCTNUMBER" class="java.lang.String"/>
		<field name="PARTTYPEID" class="java.lang.Integer"/>
		<field name="SOITEMTYPEID" class="java.lang.Integer"/>
		<field name="POSTTOTALPRICE" class="java.lang.Double"/>
		<field name="SOLINEITEM" class="java.lang.Integer"/>
		<variable name="DateFormat" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
		<variable name="BackorderTotal" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTYREMAINING}*$F{UNITPRICE}]]></variableExpression>
			<initialValueExpression><![CDATA[0]]></initialValueExpression>
		</variable>
		<variable name="ShippedTotal" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTYSHIPPED}*$F{UNITPRICE}]]></variableExpression>
			<initialValueExpression><![CDATA[0]]></initialValueExpression>
		</variable>
	</subDataset>
	<subDataset name="Dataset_Shipped" uuid="925439bc-2bc9-40ba-b08b-d321211bfc8a">
