	<queryString>
		<![CDATA[SELECT COMP.NAME AS COMPANY,
  HOMECURRENCY.SYMBOL AS HOMECURRENCYSYMBOL,
  PO.NUM AS PONUM,
  PO.VENDORSO,
  VENDOR.NAME AS VENDOR,
  PO.BUYER,
  PO.DELIVERTO,
  PO.VENDORCONTACT,
  SHIPTERMS.NAME AS SHIPTERMS,
  PAYTERMS.NAME AS PAYTERMS,
  COALESCE(QBCLASS.NAME,'') AS QBCLASS,
  CAR.NAME AS CAR,
  SVC.NAME AS SVC,
  PO.NOTE,
  PO.LOCATIONGROUPID,
  PO.DATEISSUED,
  COALESCE(PO.DATECOMPLETED,PO.DATEFIRSTSHIP) AS DATESHIP,
  PO.PHONE,
  PO.EMAIL,
  TOTAL.POTOTAL,

  COMPFAX.DATUS COMPFAX,
  COMPPHONE.DATUS COMPPHONE,
  COMPEMAIL.DATUS COMPEMAIL,
  COALESCE(COMPADDRESS.NAME,'') COMPNAME,
  COALESCE(COMPADDRESS.ADDRESS,'') COMPADDR,
  COALESCE(COMPADDRESS.CITY,'') COMPCITY,
  COALESCE(COMPSTATE.CODE,'') COMPSTATE,
  COALESCE(COMPADDRESS.ZIP,'') COMPZIP,
  COALESCE(COMPCOUNTRY.NAME,'') COMPCOUNTRY,

  PO.REMITTONAME AS BILLNAME,
  PO.REMITADDRESS AS BILLADDR,
  PO.REMITCITY AS BILLCITY,
  BILLSTATE.CODE AS BILLSTATE,
  PO.REMITZIP AS BILLZIP,
  BILLCOUNTRY.NAME AS BILLCOUNTRY,

  PO.SHIPTONAME AS SHIPNAME,
  PO.SHIPTOADDRESS AS SHIPADDR,
  PO.SHIPTOCITY AS SHIPCITY,
  SHIPSTATE.CODE AS SHIPSTATE,
  PO.SHIPTOZIP AS SHIPZIP,
  SHIPCOUNTRY.NAME AS SHIPCOUNTRY,

  POITEM.ID AS POITEMID,
  POITEM.POLINEITEM AS LINE,
  POITEMTYPE.NAME AS ITEMTYPE,
  PART.NUM PARTNUM,
  PART.DESCRIPTION PARTDESC,
  POITEM.NOTE AS ITEMNOTE,
  POITEM.DESCRIPTION AS ITEMDESC,
  POITEM.QTYTOFULFILL,
  POITEM.QTYFULFILLED,
  POITEM.UNITCOST,
  POITEM.TOTALCOST,
  UOM.CODE AS UOM,
# POITEM.VENDORPARTNUM AS CONDISH
# CustomFieldByName(POITEM.CUSTOMFIELDS, 'Condition') AS CONDISH
  ITEMCLASS.NAME AS CONDISH

FROM PO
  LEFT JOIN VENDOR ON PO.VENDORID = VENDOR.ID
  LEFT JOIN CARRIER CAR ON PO.CARRIERID = CAR.ID
  LEFT JOIN CARRIERSERVICE SVC ON SVC.ID = PO.CARRIERSERVICEID
  LEFT JOIN FOBPOINT FOB ON FOB.ID = PO.FOBPOINTID
  LEFT JOIN SHIPTERMS ON SHIPTERMS.ID = PO.SHIPTERMSID
  LEFT JOIN PAYMENTTERMS PAYTERMS ON PAYTERMS.ID = PO.PAYMENTTERMSID
  LEFT JOIN QBCLASS ON QBCLASS.ID = PO.QBCLASSID
  LEFT JOIN STATECONST BILLSTATE ON BILLSTATE.ID = PO.REMITSTATEID
  LEFT JOIN STATECONST SHIPSTATE ON SHIPSTATE.ID = PO.SHIPTOSTATEID
  LEFT JOIN COUNTRYCONST BILLCOUNTRY ON BILLCOUNTRY.ID = COALESCE(PO.REMITCOUNTRYID,BILLSTATE.COUNTRYCONSTID)
  LEFT JOIN COUNTRYCONST SHIPCOUNTRY ON SHIPCOUNTRY.ID = COALESCE(PO.SHIPTOCOUNTRYID,SHIPSTATE.COUNTRYCONSTID)

  LEFT JOIN POITEM ON POITEM.POID = PO.ID
  LEFT JOIN POITEMTYPE ON POITEMTYPE.ID = POITEM.TYPEID
  LEFT JOIN UOM ON UOM.ID = POITEM.UOMID
  LEFT JOIN PART ON PART.ID = POITEM.PARTID
  LEFT JOIN QBCLASS ITEMCLASS ON ITEMCLASS.ID = POITEM.QBCLASSID

  LEFT JOIN CURRENCY AS HOMECURRENCY ON HOMECURRENCY.HOMECURRENCY = 1
  LEFT JOIN COMPANY COMP ON COMP.ID = 1
  LEFT JOIN ADDRESS COMPADDRESS ON COMPADDRESS.ACCOUNTID = COMP.ACCOUNTID AND COMPADDRESS.TYPEID = 50 AND COMPADDRESS.DEFAULTFLAG = 1
  LEFT JOIN STATECONST COMPSTATE ON COMPSTATE.ID = COMPADDRESS.STATEID
  LEFT JOIN COUNTRYCONST COMPCOUNTRY ON COMPCOUNTRY.ID = COALESCE(COMPADDRESS.COUNTRYID, COMPSTATE.COUNTRYCONSTID)
  LEFT JOIN CONTACT COMPFAX ON COMPFAX.ACCOUNTID = COMP.ACCOUNTID AND COMPFAX.ADDRESSID = COMPADDRESS.ID AND COMPFAX.TYPEID = 40 AND COMPFAX.DEFAULTFLAG = 1
  LEFT JOIN CONTACT COMPPHONE ON COMPPHONE.ACCOUNTID = COMP.ACCOUNTID AND COMPPHONE.ADDRESSID = COMPADDRESS.ID AND COMPPHONE.TYPEID = 50 AND COMPPHONE.DEFAULTFLAG = 1
  LEFT JOIN CONTACT COMPEMAIL ON COMPEMAIL.ACCOUNTID = COMP.ACCOUNTID AND COMPEMAIL.ADDRESSID = COMPADDRESS.ID AND COMPEMAIL.TYPEID = 60 AND COMPEMAIL.DEFAULTFLAG = 1
  LEFT JOIN (
    SELECT POID,
      PO.TOTALTAX AS POTAX, PO.TOTALTAX + SUM(POITEM.TOTALCOST) AS POTOTAL
    FROM PO
      JOIN POITEM ON POITEM.POID = PO.ID
    WHERE PO.NUM = $P{poNum}
    GROUP BY 1
  ) TOTAL ON TOTAL.POID = PO.ID
WHERE PO.NUM = $P{poNum}

GROUP BY POITEMID

ORDER BY LINE]]>
	</queryString>
