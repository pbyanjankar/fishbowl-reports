	</variable>
	<variable name="GrandTotalAsset" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{QTY} *
($P{cbCostingMethod}.equals("Average Cost") ?
    $F{AVERAGEUNITCOST} :
    $F{STANDARDUNITCOST})]]></variableExpression>
	</variable>
	<variable name="GrandTotalCost" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$P{cbCostingMethod}.equals("Average Cost") ?
