<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="SalesByOrdersEnteredReportESIV2026.04" pageWidth="612" pageHeight="792" whenNoDataType="AllSectionsNoDetail" columnWidth="552" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="cc9172f7-deff-4a3e-84a2-ecccb32171d7">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<subDataset name="NewOrders" uuid="1297edc4-ce32-4e0c-a1c7-34847983e9a8">
		<parameter name="dateRange1DateShipped" class="java.util.Date">
			<parameterDescription><![CDATA[Today]]></parameterDescription>
			<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
		</parameter>
		<parameter name="dateRange2DateShipped" class="java.util.Date" isForPrompting="false">
			<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select count(id) AS IDCOUNT from so where so.dateissued between $P{dateRange1DateShipped}  and DATE_SUB($P{dateRange2DateShipped}, INTERVAL 1 SECOND)]]>
		</queryString>
		<field name="IDCOUNT" class="java.lang.Long"/>
	</subDataset>
	<subDataset name="MTDSales" uuid="85448095-60b0-4f5e-8b26-6a293ca54cb6">
		<queryString>
			<![CDATA[select COALESCE(sum(soitem.unitprice * postsoitem.qty),0) AS totalPrice

FROM postsoitem
    JOIN soitem ON postsoitem.soitemid = soitem.id
    JOIN product ON soitem.productid = product.id
    JOIN uom ON product.uomid = uom.id
    LEFT JOIN uomconversion ON (uomconversion.touomid = product.uomid AND uomconversion.fromuomid = soitem.uomid)
    JOIN company ON company.id = 1

WHERE postsoitem.datecreated between CONCAT(YEAR(Current_Date), '-', MONTH(Current_Date), '-01 0:0:0') and Current_TimeStamp
  AND soitem.typeid IN (10,12,80)]]>
		</queryString>
		<field name="TOTALPRICE" class="java.lang.Double"/>
	</subDataset>
	<subDataset name="BackOrders" uuid="3ea9abde-4f15-41d5-a014-7c4c545caf6f">
		<queryString>
			<![CDATA[select SUM(if(position('B' in so.num) = 0 and position('M' in so.num) = 0,  (soitem.qtytofulfill-soitem.qtyfulfilled) * (soitem.unitprice * (1-COALESCE(itemadjust.percentage,0)) ),0) ) as bckorder,
SUM(if(position('B' in so.num) <> 0 ,  (soitem.qtytofulfill-soitem.qtyfulfilled) * (soitem.unitprice * (1-COALESCE(itemadjust.percentage,0)) ),0) ) as blanket,
SUM(if(position('M' in so.num) <> 0,  (soitem.qtytofulfill-soitem.qtyfulfilled) * (soitem.unitprice * (1-COALESCE(itemadjust.percentage,0)) ),0) ) as makeandhold


from so
    join soitem on soitem.soid = so.id
        LEFT JOIN ( SELECT so.id as soid, soitem.id AS soitemid, MIN(sst.solineitem) sstid FROM so
            JOIN soitem on soitem.soid = so.id
            JOIN soitem as sst on sst.soid = so.id AND sst.solineitem > soitem.solineitem and sst.typeid = 40
            GROUP BY 1,2
          ) AS csst ON csst.soid = so.id AND csst.soitemid = soitem.id
    LEFT JOIN soitem AS discount on discount.soid = so.id and discount.typeid = 30 AND ( (csst.sstid+1 = discount.solineitem) OR (discount.solineitem = soitem.solineitem+1) )
    LEFT JOIN itemadjust ON itemadjust.id = discount.itemadjustid

where so.statusid in (20,25)]]>
		</queryString>
		<field name="BCKORDER" class="java.lang.Double"/>
		<field name="BLANKET" class="java.lang.Double"/>
		<field name="MAKEANDHOLD" class="java.lang.Double"/>
	</subDataset>
	<subDataset name="InventoryQtyAvailable" uuid="d5a65b38-a294-474b-8454-8416ac6e96cf">
		<queryString language="SQL">
			<![CDATA[select sum(partcost.avgCost * qtyInfo.TotalPartQuantity) as TotalDollarsAvailable
from part
inner join partcost on part.id = partcost.partid
inner join
(select
part.id as partid, SUM( if( (qtyinventorytotals.qtyonhand - qtyinventorytotals.qtyallocated)<=0,0,qtyinventorytotals.qtyonhand - qtyinventorytotals.qtyallocated )) as TotalPartQuantity
from part
inner join qtyinventorytotals on qtyinventorytotals.partid = part.id
group by part.id) qtyInfo on qtyInfo.partid = part.id]]>
		</queryString>
		<field name="TotalDollarsAvailable" class="java.lang.Double"/>
	</subDataset>
	<subDataset name="SalesNumbers" uuid="05e68837-6412-4ac3-b594-b9f390161539">
		<queryString>
			<![CDATA[SELECT

sum(result.ytd) as ytd,
sum(result.lytd) as lytd,
sum(result.blytd) as blytd,
sum(result.lycm) as lycm,
sum(result.lymtd) as lymtd

FROM
(SELECT
coalesce( sum((case when extract(year from so.dateIssued) = extract(year from current_date)
	then (SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL) + SOITEM.ADJUSTAMOUNT  else 0 end)) , 0 ) as ytd,
coalesce( sum((case when extract(year from so.dateIssued) = extract(year from current_date) - 1 and
               so.dateIssued <= date_sub(current_date, interval 1 year)
          then (SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL) + SOITEM.ADJUSTAMOUNT
          else 0 end)) , 0 ) as lytd,
coalesce(  sum((case when extract(year from so.dateIssued) = extract(year from current_date) - 2 and
               so.dateIssued <= date_sub(current_date, interval 2 year)
          then (SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL) + SOITEM.ADJUSTAMOUNT  else 0 end)) , 0 ) as blytd,
coalesce(  sum((case when extract(year from so.dateIssued) = extract(year from current_date) - 1 and
               extract(month from so.dateIssued) = extract(month from current_date)
          then (SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL) + SOITEM.ADJUSTAMOUNT  else 0 end)) , 0 ) as lycm,
coalesce(  sum((case when extract(year from so.dateIssued) = extract(year from current_date) - 1 and
               extract(month from so.dateIssued) = extract(month from current_date) and
               so.dateIssued <= date_sub(current_date, interval 1 year)
          then (SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL) + SOITEM.ADJUSTAMOUNT  else 0 end)) , 0 ) as lymtd
FROM so
inner join soitem ON soitem.soid = so.id
INNER JOIN product ON product.id = soitem.productId
INNER JOIN part ON part.id = product.partId AND part.typeid = 10
and extract(year from so.dateIssued) >= extract(year from current_date) - 2
WHERE (so.num not LIKE '%B' AND so.num not LIKE '%M')

UNION ALL

SELECT
   coalesce( sum((case when extract(year from ship.dateShipped ) = extract(year from current_date)
		then ((soitem.unitprice*postsoitem.qty)*(1-COALESCE(itemadjust.percentage,0))) else 0 end)), 0 )as ytd,
     coalesce(    sum((case when extract(year from ship.dateShipped) = extract(year from current_date) - 1 and
               ship.dateShipped <= date_sub(current_date, interval 1 year)
           then ((soitem.unitprice*postsoitem.qty)*(1-COALESCE(itemadjust.percentage,0))) else 0 end)) , 0 ) as lytd,
	coalesce( sum((case when extract(year from ship.dateShipped) = extract(year from current_date) - 2 and
              ship.dateShipped <= date_sub(current_date, interval 2 year)
          then ((soitem.unitprice*postsoitem.qty)*(1-COALESCE(itemadjust.percentage,0))) else 0 end)) , 0 ) as blytd,
	coalesce( sum((case when extract(year from ship.dateShipped) = extract(year from current_date) - 1 and
               extract(month from ship.dateShipped) = extract(month from current_date)
          then ((soitem.unitprice*postsoitem.qty)*(1-COALESCE(itemadjust.percentage,0))) else 0 end)) , 0 ) as lycm,
	coalesce( sum((case when extract(year from ship.dateShipped) = extract(year from current_date) - 1 and
               extract(month from ship.dateShipped) = extract(month from current_date) and
               ship.dateShipped <= date_sub(current_date, interval 1 year)
          then ((soitem.unitprice*postsoitem.qty)*(1-COALESCE(itemadjust.percentage,0))) else 0 end)) , 0 ) as lymtd
	FROM postso
	JOIN postsoitem on postsoitem.postsoid = postso.id
	JOIN soitem on soitem.id = postsoitem.soitemid
	JOIN shipitem ON shipitem.id = postsoitem.shipitemid
	JOIN ship ON ship.id = shipitem.shipid
    and extract(year from ship.dateShipped) >= extract(year from current_date) - 2
	JOIN so ON so.id = ship.soid
	LEFT JOIN ( SELECT so.id as soid, soitem.id AS soitemid, MIN(sst.solineitem) sstid FROM so
            JOIN soitem on soitem.soid = so.id
            JOIN soitem as sst on sst.soid = so.id AND sst.solineitem > soitem.solineitem and sst.typeid = 40
            GROUP BY 1,2
          ) AS csst ON csst.soid = so.id AND csst.soitemid = soitem.id
    LEFT JOIN soitem AS discount on discount.soid = so.id and discount.typeid = 30 AND ( (csst.sstid+1 = discount.solineitem) OR (discount.solineitem = soitem.solineitem+1) )
    LEFT JOIN itemadjust ON itemadjust.id = discount.itemadjustid

WHERE (so.num LIKE '%B' OR so.num LIKE '%M') ) as result]]>
		</queryString>
		<field name="YTD" class="java.lang.Double"/>
		<field name="LYTD" class="java.lang.Double"/>
		<field name="BLYTD" class="java.lang.Double"/>
		<field name="LYMTD" class="java.lang.Double"/>
		<field name="LYCM" class="java.lang.Double"/>
	</subDataset>
	<subDataset name="InventoryValue" uuid="890057fc-402c-4030-b764-0ded7af11188">
		<queryString language="SQL">
			<![CDATA[select SUM(partcost.avgcost * qoh.qty) as ivalue

from part
    join (select tag.partid, SUM(tag.qty) as qty from tag group by 1 ) as qoh on qoh.partid = part.id
    join partcost on partcost.partid = part.id]]>
		</queryString>
		<field name="IVALUE" class="java.lang.Double"/>
	</subDataset>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Show Sales Orders based on issue date. if the sales order has a letter in it (i.e. B or M) then the report to show Sales Orders that SHIPPED"]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[This Month]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Program Files/Fishbowl/Server/reports/WorkOrder/"]]></defaultValueExpression>
	</parameter>
	<parameter name="soNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="customerID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="salesPerson" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckShowDetails" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[1,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
COALESCE(customset.info, "") AS CUSTOMERCATEGORY,
so.num AS NUM,
customer.name AS CustomerName,
so.dateIssued AS DATES,
so.salesman AS SALESPERSON,
sostatus.name AS STATUS,
company.name AS company,
sototal.TOTALPRICE AS TOTALPRICE
FROM so
INNER JOIN sostatus ON sostatus.id = so.statusId
JOIN company on company.id = 1
JOIN customer ON customer.id = so.customerid
LEFT JOIN ( SELECT so.id as soid, sum((SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL) + SOITEM.ADJUSTAMOUNT) AS TOTALPRICE
	  	FROM so
            	INNER JOIN soitem on soitem.soid = so.id
		INNER JOIN product ON product.id = soitem.productId
		INNER JOIN part ON part.id = product.partId AND part.typeid = 10
            GROUP BY 1
          ) AS sototal ON sototal.soid = so.id

LEFT OUTER JOIN tablereference ON tablerefname = "customer"
LEFT OUTER JOIN customfield ON tablereference.tableid = customfield.tableId AND customfield.name = "Customer Category"
LEFT OUTER JOIN customset ON customset.recordId = customer.id AND customfield.id = customset.customfieldid


WHERE UPPER(so.num) LIKE UPPER($P{soNum}) AND (so.num not LIKE '%B' AND so.num not LIKE '%M')
  AND UPPER(so.salesman) LIKE UPPER($P{salesPerson})
  AND so.customerid LIKE $P{customerID}
  AND so.dateIssued BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)

UNION

SELECT
COALESCE(customset.info, "") AS CUSTOMERCATEGORY,
so.num AS NUM,
customer.name AS CustomerName,
shipped.dateShipped AS DATESHIPPED,
so.salesman AS SALESPERSON,
sostatus.name AS STATUS,
company.name AS company,
shipped.shippedprice AS TOTALSHIPPEDPRICE
FROM so
INNER JOIN sostatus ON sostatus.id = so.statusId
JOIN company on company.id = 1
JOIN customer ON customer.id = so.customerid

LEFT OUTER JOIN (

	SELECT
		ship.soid AS soid,
		ship.id AS shipid,
		max(dateshipped) dateShipped,
		sum(((soitem.unitprice*postsoitem.qty)*(1-COALESCE(itemadjust.percentage,0)))) AS shippedprice
	FROM postso
	JOIN postsoitem on postsoitem.postsoid = postso.id
	JOIN soitem on soitem.id = postsoitem.soitemid
	JOIN shipitem ON shipitem.id = postsoitem.shipitemid
	JOIN ship ON ship.id = shipitem.shipid
	JOIN so ON so.id = ship.soid
	LEFT JOIN ( SELECT so.id as soid, soitem.id AS soitemid, MIN(sst.solineitem) sstid FROM so
            JOIN soitem on soitem.soid = so.id
            JOIN soitem as sst on sst.soid = so.id AND sst.solineitem > soitem.solineitem and sst.typeid = 40
            GROUP BY 1,2
          ) AS csst ON csst.soid = so.id AND csst.soitemid = soitem.id
    	LEFT JOIN soitem AS discount on discount.soid = so.id and discount.typeid = 30 AND ( (csst.sstid+1 = discount.solineitem) OR (discount.solineitem = soitem.solineitem+1) )
    	LEFT JOIN itemadjust ON itemadjust.id = discount.itemadjustid

          WHERE UPPER(so.num) LIKE UPPER($P{soNum})
               AND UPPER(so.salesman) LIKE UPPER($P{salesPerson})
               AND so.customerid LIKE $P{customerID}
               AND ship.dateShipped BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
	GROUP BY ship.soid, ship.id
) AS shipped ON shipped.soid = so.id

LEFT OUTER JOIN tablereference ON tablerefname = "customer"
LEFT OUTER JOIN customfield ON tablereference.tableid = customfield.tableId AND customfield.name = "Customer Category"
LEFT OUTER JOIN customset ON customset.recordId = customer.id AND customfield.id = customset.customfieldid



WHERE UPPER(so.num) LIKE UPPER($P{soNum}) AND (so.num LIKE '%B' OR so.num LIKE '%M')
  AND UPPER(so.salesman) LIKE UPPER($P{salesPerson})
  AND so.customerid LIKE $P{customerID}
  AND shipped.dateShipped BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)



ORDER BY
CASE CUSTOMERCATEGORY
    WHEN "Standard" THEN 0
    WHEN  "Maintenance" THEN 1
    WHEN  "Prime" THEN 2
    WHEN  "Prime Maintenance" THEN 3
    WHEN  "House" THEN 4
    ELSE 5
END ASC, DATES ASC;]]>
	</queryString>
	<field name="NUM" class="java.lang.String"/>
	<field name="CustomerName" class="java.lang.String"/>
	<field name="DATES" class="java.sql.Timestamp"/>
	<field name="STATUS" class="java.lang.String"/>
	<field name="SALESPERSON" class="java.lang.String"/>
	<field name="TOTALPRICE" class="java.lang.Double"/>
	<field name="COMPANY" class="java.lang.String"/>
	<field name="CUSTOMERCATEGORY" class="java.lang.String"/>
	<variable name="DateFormat" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
	</variable>
	<variable name="PriceDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
	</variable>
	<variable name="CategoryTotalPrice" class="java.lang.Double" resetType="Group" resetGroup="CustomerCategory" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTALPRICE}]]></variableExpression>
	</variable>
	<variable name="GrandTotalPrice" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTALPRICE}]]></variableExpression>
	</variable>
