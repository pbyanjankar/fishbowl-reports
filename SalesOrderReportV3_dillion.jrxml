<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="SalesOrderReportV3 DILLION" pageWidth="792" pageHeight="612" orientation="Landscape" columnWidth="752" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="7" uuid="7f5fa723-b3d7-4eef-8351-4dfda91d2a0a">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<subDataset name="Items" uuid="62fdc006-6870-4457-a51e-e056d45d6874">
		<parameter name="soID" class="java.lang.Integer">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT soitem.qtytofulfill AS qty,
soitem.productnum,
soitem.description,
"" AS lotCode,
part.weight AS weight,
soitem.totalPrice AS extPrice,
soitem.note AS itemNotes,
COALESCE(uom.code, "") AS weightUOM,
soitem.typeid AS itemType

FROM soitem
LEFT JOIN product ON soitem.productid = product.id
LEFT JOIN part ON product.partid = part.id
LEFT JOIN uom ON part.weightuomid = uom.id

WHERE soitem.soid = $P!{soID}


ORDER BY soitem.productnum]]>
		</queryString>
		<field name="qty" class="java.lang.Double"/>
		<field name="productNum" class="java.lang.String"/>
		<field name="description" class="java.lang.String"/>
		<field name="lotCode" class="java.lang.String"/>
		<field name="weight" class="java.lang.Double"/>
		<field name="extPrice" class="java.lang.Double"/>
		<field name="itemNotes" class="java.lang.String"/>
		<field name="weightUOM" class="java.lang.String"/>
		<field name="itemType" class="java.lang.Integer"/>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="totalQty" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{qty}]]></variableExpression>
		</variable>
		<variable name="totalWeight" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[($F{weight} * $F{qty})]]></variableExpression>
		</variable>
		<variable name="totalPrice" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{itemType} == 40 ? 0 : $F{extPrice}]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="soNum" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT DISTINCT company.name AS company,
so.num AS soNum,
customer.name AS customer,
(CASE
    WHEN LOCATE("ATTN", IF(LOCATE("ATTN", so.billtoaddress) = 0, so.shiptoaddress, so.billtoaddress)) = 0
    THEN CONCAT("ATTN: ", so.customerContact)
    ELSE IF(LOCATE("ATTN", so.billtoaddress) = 0, so.shiptoaddress, so.billtoaddress)
END) AS contact,
(CASE
    WHEN LOCATE("ATTN", IF(LOCATE("ATTN", so.billtoaddress) = 0, so.shiptoaddress, so.billtoaddress)) = 0
    THEN so.billtoaddress
    ELSE null
    END) AS billtoaddress,
so.billtocity,
billtostate.code AS billtostate,
so.billtozip AS billtozip,
billtocountry.name AS billtocountry,
COALESCE(customfieldbyname(customer.customfields, "Tax Exempt Number"), "") AS resaleTaxNum,
so.phone AS customerPhone,
COALESCE(contact.datus, "") AS customerFax,
COALESCE(so.email, "") AS customerEmail,
carrier.name AS deliveryTerms,
so.customerPO AS customerPO,
so.salesman AS salesRep,
customer.number AS customerAccountNumber,
so.dateIssued AS orderDate,
customfieldbyname(so.customfields, "Cancel Date") AS cancelDate,
so.datefirstShip AS shipDate,
paymentterms.name AS paymentterms,
so.shiptoname AS shipToName,
so.shiptoaddress AS shiptoaddress,
so.shiptocity AS shiptocity,
COALESCE(shiptostate.code, "" ) AS shiptostate,
so.shiptozip AS shiptozip,
shiptocountry.name AS shiptocountry,
customer.note AS AlertNote,
memo.memo AS orderNotes,
so.id AS soID,
totalPaid.totalPaid,
so.totalPrice

FROM so
LEFT JOIN customer ON so.customerid = customer.id
LEFT JOIN stateconst AS billtostate ON so.billtostateid = billtostate.id
LEFT JOIN countryconst AS billtocountry ON so.billtocountryid = billtocountry.id
LEFT JOIN stateconst AS shiptostate ON so.shiptostateid = shiptostate.id
LEFT JOIN countryconst AS shiptocountry ON so.shiptocountryid = shiptocountry.id
LEFT JOIN contact ON customer.accountid = contact.accountid AND contact.typeid = 40
LEFT JOIN carrier ON so.carrierid = carrier.id
LEFT JOIN paymentterms ON customer.defaultpaymenttermsid = paymentterms.id
LEFT JOIN company ON company.id = 1
LEFT JOIN (SELECT SUM(postransaction.amount) AS totalPaid, postransaction.soid
	FROM postransaction
	GROUP BY soid
	) AS totalPaid ON totalPaid.soid = so.id
LEFT JOIN memo ON memo.recordid = so.id AND memo.tableid = 1012013120

WHERE so.num = $P{soNum}]]>
	</queryString>
