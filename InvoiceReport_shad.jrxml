<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="InvoiceReportSHAD" pageWidth="1008" pageHeight="612" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="966" leftMargin="21" rightMargin="21" topMargin="21" bottomMargin="21" uuid="9c7e3592-782a-4dbf-8f3f-53a4476c070b">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.1"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="locationGroupID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["-1"]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
		<parameterDescription><![CDATA[This Month]]></parameterDescription>
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="customerID" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
  so.num AS SONUM,
  so.VENDORPO,
  customer.name AS CUSTOMER,
  lg.name AS LG,
  shipcarton.trackingnum AS TRACKNUM,
  shipitem.qtyshipped AS QTY,
  soitem.unitprice AS UNITPRICE,
  shipitem.qtyshipped * soitem.unitprice AS TOTALPRICE,
  part.num AS PART,
  uom.code AS UOM,
  ship.dateshipped AS SHIPDATE,
  COALESCE(sototals.shiptotal * (soitem.unitprice * shipitem.qtyshipped / sototals.saletotal),0) AS SHIPFEE,
  company.name AS COMPANY,
  ROUND(COALESCE(SOTOTALS.SHIPTOTAL,0) / COALESCE(SOTOTALS.QT,0),4) AS SHIPPING,
  carrierservice.name AS SHIPPINGMETHOD
FROM ship
  JOIN shipitem ON shipitem.shipid = ship.id
  JOIN shipcarton ON shipcarton.id = shipitem.shipcartonid
  JOIN soitem ON soitem.id = shipitem.soitemid
  JOIN so ON so.id = soitem.soid
  JOIN customer ON customer.id = so.customerid
  JOIN locationgroup lg ON lg.id = so.locationgroupid
  JOIN product ON product.id = soitem.productid
  JOIN part ON part.id = product.partid
  LEFT JOIN uom ON uom.id = shipitem.uomid
  LEFT OUTER JOIN carrierservice ON carrierservice.id = ship.carrierserviceId
  JOIN company ON company.id = 1
  LEFT JOIN (
    SELECT soitem.soid, SUM(IF(SOITEM.TYPEID!=60,SOITEM.QTYORDERED,0)) AS QT,
      SUM(IF(soitem.typeid =60,soitem.totalprice,0)) AS shiptotal,
      SUM(IF(soitem.typeid!=60,soitem.totalprice,0)) AS saletotal
    FROM soitem
    GROUP BY 1
  ) sototals ON sototals.soid = so.id

WHERE 1=1
  AND ship.dateshipped BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
  AND customer.id LIKE $P{customerID}

ORDER BY #ship.dateshipped,
  ship.num, part.num]]>
	</queryString>
