		<variableExpression><![CDATA["MM/dd/yyyy"]]></variableExpression>
	</variable>
	<group name="CustomerAddress">
		<groupExpression><![CDATA[new Integer(1)]]></groupExpression>
		<groupHeader>
			<band height="82">
				<textField isStretchWithOverflow="true" pattern="" isBlankWhenNull="true">
					<reportElement key="textField-5" mode="Transparent" x="281" y="17" width="271" height="55" forecolor="#000000" backcolor="#FFFFFF" uuid="e3083f10-af48-4447-bc2b-d44af7e9e78f"/>
