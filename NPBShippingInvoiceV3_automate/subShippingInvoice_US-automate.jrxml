	<variable name="CustomerContact" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[(($F{CUSTOMERCONTACT} != null) && (!$F{CUSTOMERCONTACT}.equals(""))) ? "Contact: " + $F{CUSTOMERCONTACT} : ""]]></variableExpression>
	</variable>
	<variable name="CustomerPO" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA[(($F{CUSTOMERPO} != null) && (!$F{CUSTOMERPO}.equals(""))) ? "PO Number: " + $F{CUSTOMERPO} : ""]]></variableExpression>
	</variable>
	<variable name="PriceDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA["$ #,##0.00"]]></variableExpression>
	</variable>
	<variable name="QtyDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA["#,##0.#####"]]></variableExpression>
	</variable>
	<variable name="CostDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA["$ #,##0.00"]]></variableExpression>
	</variable>
	<variable name="taxTotal" class="java.lang.Double">
		<variableExpression><![CDATA[com.evnt.eve.modules.ReportHelperModule.getRoundedMoneyValue($F{TAXRATE} < 0 ? 0.0 : $F{TAXRATE} , true)]]></variableExpression>
	</variable>
	<variable name="subTotal" class="java.lang.Double">
		<variableExpression><![CDATA[com.evnt.eve.modules.ReportHelperModule.getRoundedMoneyValue($F{SUBTOTAL}.doubleValue(), true)]]></variableExpression>
	</variable>
	<variable name="TotalsDecimal" class="java.lang.String" resetType="None">
		<variableExpression><![CDATA["$ #,##0.00"]]></variableExpression>
	</variable>
	<variable name="isMultiCurrency" class="java.lang.Boolean">
		<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
	</variable>
	<variable name="HCSubTotal" class="java.lang.Double">
		<variableExpression><![CDATA[com.evnt.eve.modules.ReportHelperModule.getRoundedMoneyValue((($F{CURRENCYSUBTOTAL} + $F{CURRENCYTAXTOTAL}) * $F{CURRENCYRATE}), true) - ($F{CURRENCYTAXTOTAL} * $F{CURRENCYRATE})]]></variableExpression>
	</variable>
	<variable name="currencySubTotal" class="java.lang.Double">
		<variableExpression><![CDATA[com.evnt.eve.modules.ReportHelperModule.getRoundedMoneyValue($F{CURRENCYSUBTOTAL}, true)]]></variableExpression>
	</variable>
	<variable name="currencyTaxTotal" class="java.lang.Double">
		<variableExpression><![CDATA[com.evnt.eve.modules.ReportHelperModule.getRoundedMoneyValue($F{CURRENCYTAXTOTAL} < 0 ? 0.0 : $F{CURRENCYTAXTOTAL} , true)]]></variableExpression>
	</variable>
