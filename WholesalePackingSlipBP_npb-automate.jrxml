where so.id = $P{soId} and shipid <=  $P{shipID})
group by soitemid, KitParentId
UNION ALL
select KitParentId, "" as Child, min(totalshipped)  as totalshipped from (
select ObjectToObject.recordId1, ObjectToObject.recordId2 as KitParentId, sum(qtyshipped) as totalshipped from shipitem
LEFT JOIN ObjectToObject ON ObjectToObject.typeId =30 AND recordid1 = shipitem.soitemid
where ObjectToObject.recordId2 is not null AND
shipid in
 (select ship.id from ship
 INNER JOIN so on so.id = ship.soid
where so.id = $P{soId} and shipid <=  $P{shipID})
group by ObjectToObject.recordId1, KitParentId) as t2
group by KitParentId
) AS t
on soitem.id = t.soitemid
LEFT JOIN product on product.id = soitem.productId
LEFT JOIN part ON part.id = product.partId
INNER JOIN SoItemType ON SoItem.typeId = SoItemType.id AND soitem.typeid != 40
INNER JOIN Uom AS SoItemUom ON soitem.uomId = SoItemUom.id
LEFT JOIN postsoitem on postsoitem.soitemid = soitem.id and postsoitem.postsoid = $P{postSoId}
