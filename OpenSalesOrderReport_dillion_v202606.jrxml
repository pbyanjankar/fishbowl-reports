	</parameter>
	<parameter name="Category" class="java.lang.String" isForPrompting="false">
		<property name="Group" value="Filters"/>
		<parameterDescription><![CDATA[]]></parameterDescription>
	</parameter>
	<parameter name="ShowPartsWithNoSalesOrders" class="java.lang.Boolean" isForPrompting="false">
		<property name="Group" value="Filters"/>
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
CASE
  WHEN CustomFieldByName(product.customFields, "Choc Dark") = "true" THEN "Choc Dark"
  WHEN CustomFieldByName(product.customFields, "Choc Milk") = "true" THEN "Choc Milk"
  WHEN CustomFieldByName(product.customFields, "Divinity Pecan") = "true" THEN "Divinity Pecan"
  WHEN CustomFieldByName(product.customFields, "Divinity Peppermint") = "true" THEN "Divinity Peppermint"
  WHEN CustomFieldByName(product.customFields, "Praline 1oz") = "true" THEN "Praline 1oz"
  WHEN CustomFieldByName(product.customFields, "CC Nut Praline") = "true" THEN "CC Nut Praline"
  WHEN CustomFieldByName(product.customFields, "CC Nut Cinnamon") = "true" THEN "CC Nut Cinnamon"
  WHEN CustomFieldByName(product.customFields, "CC Nut Pumpkin") = "true" THEN "CC Nut Pumpkin"
  WHEN CustomFieldByName(product.customFields, "Roll Pecan") = "true" THEN "Roll Pecan"
  WHEN CustomFieldByName(product.customFields, "Roll Cashew") = "true" THEN "Roll Cashew"
  WHEN CustomFieldByName(product.customFields, "Roll Peanut") = "true" THEN "Roll Peanut"
  WHEN CustomFieldByName(product.customFields, "Roll Penuche") = "true" THEN "Roll Penuche"
  WHEN CustomFieldByName(product.customFields, "Divinity Celebrate") = "true" THEN "Divinity Celebrate"
  WHEN CustomFieldByName(product.customFields, "Brittle Pecan") = "true" THEN "Brittle Pecan"
  WHEN CustomFieldByName(product.customFields, "Brittle Peanut") = "true" THEN "Brittle Peanut"
  WHEN CustomFieldByName(product.customFields, ".Retail Box") = "true" THEN ".Retail Box"
  WHEN CustomFieldByName(product.customFields, ".Gift") = "true" THEN ".Gift"
  WHEN CustomFieldByName(product.customFields, "Divinity No Nut") = "true" THEN "Divinity No Nut"
  WHEN CustomFieldByName(product.customFields, ".Pecan Halves") = "true" THEN ".Pecan Halves"
  WHEN CustomFieldByName(product.customFields, "Divinity Apple Pie") = "true" THEN "Divinity Apple Pie"
ELSE "No Category" END AS productCategory,
product.num AS prodNum,
product.description AS prodDesc,
uom.code AS uom,
COALESCE(INVENTORYTOTALS.TOTALONORDER,0) AS ONORDER,
COALESCE(INVENTORYTOTALS.TOTALONHAND,0) AS QOH,
COALESCE(qtyScheduled.qty,0) AS qtyScheduled,
COALESCE(woScheduled.qty,0) AS woQtyScheduled



FROM product
LEFT JOIN uom ON product.uomid = uom.id
LEFT JOIN part ON product.partid = part.id
LEFT JOIN (
   SELECT partId,
         SUM(qtyOnHand) AS totalOnHand,
         SUM(qtyNotAvailable) AS totalNotAvailable,
         SUM(qtyNotAvailabletopick) AS totalNotAvailabletopick,
         SUM(qtyDropship) AS totalDropship,
         SUM(qtyAllocated) AS totalAllocated,
         SUM(qtyOnOrder) AS totalOnOrder
      FROM qtyInventoryTotals
      GROUP BY partId
   ) AS inventoryTotals ON inventoryTotals.partId = part.id
LEFT JOIN (
   SELECT SUM(soitem.qtyToFulfill) AS qty, soitem.productid
   FROM soitem
      LEFT JOIN so ON soitem.soid = so.id
   WHERE so.statusid = 20
      AND DATE(so.datefirstship) BETWEEN $P{dateRange1} AND $P{dateRange2}
   GROUP BY productid
   ) AS qtyScheduled ON qtyScheduled.productid = product.id
LEFT JOIN (
   SELECT SUM(woitem.qtyTarget) AS qty, woitem.partid
   FROM woitem
   LEFT JOIN wo ON woitem.woid = wo.id
   WHERE wo.statusid < 40
   GROUP BY partid
   ) AS woScheduled ON woScheduled.partid = part.id

WHERE product.num LIKE $P{productNum}
AND (CASE
  WHEN CustomFieldByName(product.customFields, "Choc Dark") = "true" THEN "Choc Dark"
  WHEN CustomFieldByName(product.customFields, "Choc Milk") = "true" THEN "Choc Milk"
  WHEN CustomFieldByName(product.customFields, "Divinity Pecan") = "true" THEN "Divinity Pecan"
  WHEN CustomFieldByName(product.customFields, "Divinity Peppermint") = "true" THEN "Divinity Peppermint"
  WHEN CustomFieldByName(product.customFields, "Praline 1oz") = "true" THEN "Praline 1oz"
  WHEN CustomFieldByName(product.customFields, "CC Nut Praline") = "true" THEN "CC Nut Praline"
  WHEN CustomFieldByName(product.customFields, "CC Nut Cinnamon") = "true" THEN "CC Nut Cinnamon"
  WHEN CustomFieldByName(product.customFields, "CC Nut Pumpkin") = "true" THEN "CC Nut Pumpkin"
  WHEN CustomFieldByName(product.customFields, "Roll Pecan") = "true" THEN "Roll Pecan"
  WHEN CustomFieldByName(product.customFields, "Roll Cashew") = "true" THEN "Roll Cashew"
  WHEN CustomFieldByName(product.customFields, "Roll Peanut") = "true" THEN "Roll Peanut"
  WHEN CustomFieldByName(product.customFields, "Roll Penuche") = "true" THEN "Roll Penuche"
  WHEN CustomFieldByName(product.customFields, "Divinity Celebrate") = "true" THEN "Divinity Celebrate"
  WHEN CustomFieldByName(product.customFields, "Brittle Pecan") = "true" THEN "Brittle Pecan"
  WHEN CustomFieldByName(product.customFields, "Brittle Peanut") = "true" THEN "Brittle Peanut"
  WHEN CustomFieldByName(product.customFields, ".Retail Box") = "true" THEN ".Retail Box"
  WHEN CustomFieldByName(product.customFields, ".Gift") = "true" THEN ".Gift"
  WHEN CustomFieldByName(product.customFields, "Divinity No Nut") = "true" THEN "Divinity No Nut"
  WHEN CustomFieldByName(product.customFields, ".Pecan Halves") = "true" THEN ".Pecan Halves"
  WHEN CustomFieldByName(product.customFields, "Divinity Apple Pie") = "true" THEN "Divinity Apple Pie"
ELSE "No Category" END) LIKE CONCAT("%", $P{Category}, "%")
AND IF($P!{ShowPartsWithNoSalesOrders}, 1=1, COALESCE(qtyScheduled.qty,0) != 0)

ORDER BY productCategory, prodDesc]]>
	</queryString>
