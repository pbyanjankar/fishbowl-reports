			<textField pattern="" isBlankWhenNull="true">
				<reportElement key="textField-14" mode="Transparent" x="290" y="0" width="42" height="14" forecolor="#000000" backcolor="#FFFFFF" uuid="dae19792-bf5a-4eff-b76c-b030f2bd0333"/>
				<box rightPadding="2">
