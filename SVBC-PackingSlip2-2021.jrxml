	</parameter>
	<queryString>
		<![CDATA[SELECT COMP.NAME AS COMPANY,
  HOMECURRENCY.SYMBOL AS HOMECURRENCYSYMBOL,
  SO.NUM AS SONUM,
  SO.CUSTOMERPO,
  SO.VENDORPO,
  CUSTOMER.NAME AS CUSTOMER,
  TOPCUSTOMER.NAME AS TOPCUSTOMER,
  JOBCUSTOMER.NAME AS JOBCUSTOMER,
  SHIPTERMS.NAME AS SHIPTERMS,
  PAYTERMS.NAME AS PAYTERMS,
  COALESCE(QBCLASS.NAME,'') AS QBCLASS,
  FOB.NAME AS FOB,
  CAR.NAME AS CAR,
  SVC.NAME AS SVC,
  SO.NOTE,
  SO.LOCATIONGROUPID,
  SO.DATEISSUED,
  COALESCE(SO.DATECOMPLETED,SO.DATEFIRSTSHIP) AS DATESHIP,
  SO.SALESMAN,
  SALESREP.INITIALS AS SALESREP,	#CONCAT(SALESREP.FIRSTNAME,' ',SALESREP.LASTNAME)
  SO.CUSTOMERCONTACT,
  SO.PHONE,
  SO.EMAIL,

  TOTAL.SUBTOTAL,
  TOTAL.SOTAX,
  TOTAL.SOTOTAL,
  COALESCE(PAID.PAID,0) AS SOPAID,
  TOTAL.SOTOTAL - COALESCE(PAID.PAID,0) AS SODUE,

  COMPFAX.DATUS COMPFAX,
  COMPPHONE.DATUS COMPPHONE,
  COMPEMAIL.DATUS COMPEMAIL,
  COALESCE(COMPADDRESS.NAME,'') COMPNAME,
  COALESCE(COMPADDRESS.ADDRESS,'') COMPADDR,
  COALESCE(COMPADDRESS.CITY,'') COMPCITY,
  COALESCE(COMPSTATE.CODE,'') COMPSTATE,
  COALESCE(COMPADDRESS.ZIP,'') COMPZIP,
  COALESCE(COMPCOUNTRY.NAME,'') COMPCOUNTRY,

  SO.BILLTONAME AS BILLNAME,
  SO.BILLTOADDRESS AS BILLADDR,
  SO.BILLTOCITY AS BILLCITY,
  BILLSTATE.CODE AS BILLSTATE,
  SO.BILLTOZIP AS BILLZIP,
  BILLCOUNTRY.NAME AS BILLCOUNTRY,

  SO.SHIPTONAME AS SHIPNAME,
  SO.SHIPTOADDRESS AS SHIPADDR,
  SO.SHIPTOCITY AS SHIPCITY,
  SHIPSTATE.CODE AS SHIPSTATE,
  SO.SHIPTOZIP AS SHIPZIP,
  SHIPCOUNTRY.NAME AS SHIPCOUNTRY

FROM SO
  LEFT JOIN CUSTOMER ON SO.CUSTOMERID = CUSTOMER.ID
  LEFT JOIN CUSTOMER TOPCUSTOMER ON TOPCUSTOMER.ID = COALESCE(CUSTOMER.PARENTID, CUSTOMER.ID)
  LEFT JOIN CUSTOMER JOBCUSTOMER ON JOBCUSTOMER.ID = CUSTOMER.ID AND CUSTOMER.PARENTID IS NOT NULL
  LEFT JOIN SYSUSER SALESREP ON SALESREP.ID = SO.SALESMANID
  LEFT JOIN CARRIER CAR ON SO.CARRIERID = CAR.ID
  LEFT JOIN CARRIERSERVICE SVC ON SVC.ID = SO.CARRIERSERVICEID
  LEFT JOIN FOBPOINT FOB ON FOB.ID = SO.FOBPOINTID
  LEFT JOIN SHIPTERMS ON SHIPTERMS.ID = SO.SHIPTERMSID
  LEFT JOIN PAYMENTTERMS PAYTERMS ON PAYTERMS.ID = SO.PAYMENTTERMSID
  LEFT JOIN QBCLASS ON QBCLASS.ID = SO.QBCLASSID
  LEFT JOIN STATECONST BILLSTATE ON BILLSTATE.ID = SO.BILLTOSTATEID
  LEFT JOIN STATECONST SHIPSTATE ON SHIPSTATE.ID = SO.SHIPTOSTATEID
  LEFT JOIN COUNTRYCONST BILLCOUNTRY ON BILLCOUNTRY.ID = COALESCE(SO.BILLTOCOUNTRYID,BILLSTATE.COUNTRYCONSTID)
  LEFT JOIN COUNTRYCONST SHIPCOUNTRY ON SHIPCOUNTRY.ID = COALESCE(SO.SHIPTOCOUNTRYID,SHIPSTATE.COUNTRYCONSTID)

  LEFT JOIN CURRENCY AS HOMECURRENCY ON HOMECURRENCY.HOMECURRENCY = 1
  LEFT JOIN COMPANY COMP ON COMP.ID = 1
  LEFT JOIN ADDRESS COMPADDRESS ON COMPADDRESS.ACCOUNTID = COMP.ACCOUNTID AND COMPADDRESS.TYPEID = 50 AND COMPADDRESS.DEFAULTFLAG = 1
  LEFT JOIN STATECONST COMPSTATE ON COMPSTATE.ID = COMPADDRESS.STATEID
  LEFT JOIN COUNTRYCONST COMPCOUNTRY ON COMPCOUNTRY.ID = COALESCE(COMPADDRESS.COUNTRYID, COMPSTATE.COUNTRYCONSTID)
  LEFT JOIN CONTACT COMPFAX ON COMPFAX.ACCOUNTID = COMP.ACCOUNTID AND COMPFAX.ADDRESSID = COMPADDRESS.ID AND COMPFAX.TYPEID = 40 AND COMPFAX.DEFAULTFLAG = 1
  LEFT JOIN CONTACT COMPPHONE ON COMPPHONE.ACCOUNTID = COMP.ACCOUNTID AND COMPPHONE.ADDRESSID = COMPADDRESS.ID AND COMPPHONE.TYPEID = 50 AND COMPPHONE.DEFAULTFLAG = 1
  LEFT JOIN CONTACT COMPEMAIL ON COMPEMAIL.ACCOUNTID = COMP.ACCOUNTID AND COMPEMAIL.ADDRESSID = COMPADDRESS.ID AND COMPEMAIL.TYPEID = 60 AND COMPEMAIL.DEFAULTFLAG = 1
  LEFT JOIN (
    SELECT SOID,
      SUM(SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL) AS SUBTOTAL,
      SUM(SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL * SOITEM.TAXABLEFLAG) AS TAXABLESUBTOTAL,
      SO.TOTALTAX AS SOTAX, SO.TOTALTAX + SUM(SOITEM.UNITPRICE * SOITEM.QTYTOFULFILL) AS SOTOTAL
    FROM SO
      JOIN SOITEM ON SOITEM.SOID = SO.ID AND SOITEM.TYPEID NOT IN(40)
    WHERE SO.NUM = $P{soNum}
    GROUP BY 1
  ) TOTAL ON TOTAL.SOID = SO.ID
  LEFT JOIN (
    SELECT SOID, SUM(AMOUNT) AS PAID
    FROM SO JOIN POSTRANSACTION ON POSTRANSACTION.SOID = SO.ID
    WHERE SO.NUM = $P{soNum}
    GROUP BY 1
  ) AS PAID ON SO.ID = PAID.SOID

WHERE SO.NUM = $P{soNum}]]>
	</queryString>
