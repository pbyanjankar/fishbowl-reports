	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["4x3 Shipping Label"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="shipID" class="java.lang.String">
		<defaultValueExpression><![CDATA["7"]]></defaultValueExpression>
	</parameter>
	<parameter name="ckShowCountry" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[1,0]]></parameterDescription>
		<defaultValueExpression><![CDATA["1"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT

    SHIP.ID AS SHIPID,
    COALESCE(SHIP.SHIPTONAME, '') AS SHIPTONAME,
    SHIP.SHIPTOADDRESS AS SHIPTOADDRESS,
    SHIP.SHIPTOCITY AS SHIPTOCITY,
    SHIPSTATE.CODE AS SHIPTOSTATE,
    SHIP.SHIPTOZIP AS SHIPTOZIP,
    SHIP.NUM AS SHIPNUM,
    SHIPCOUNTRY.NAME AS SHIPCOUNTRY,
    COMPANY.NAME AS COMPANY
FROM
    ship
    LEFT OUTER JOIN stateconst shipState ON ship.shiptostateid = shipState.id
    LEFT OUTER JOIN countryconst shipCountry ON ship.shiptocountryid = shipCountry.id
    JOIN company ON company.id = 1
WHERE
    ship.id = $P{shipID}]]>
	</queryString>
	<field name="SHIPID" class="java.lang.Integer"/>
	<field name="SHIPTONAME" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="SHIPTOADDRESS" class="java.lang.String">
