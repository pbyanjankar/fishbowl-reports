	<field name="prodNum" class="java.lang.String"/>
	<field name="prodDesc" class="java.lang.String"/>
	<field name="uom" class="java.lang.String"/>
	<field name="ONORDER" class="java.lang.Double"/>
	<field name="QOH" class="java.lang.Double"/>
	<field name="qtyScheduled" class="java.lang.Double"/>
	<field name="woQtyScheduled" class="java.lang.Double"/>
