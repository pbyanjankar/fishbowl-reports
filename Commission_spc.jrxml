<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Commission SPC" pageWidth="612" pageHeight="792" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="cf596ac9-850b-4b49-825c-0e686a61d324">
	<property name="ireport.zoom" value="1.4641000000000015"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="dateRange1ReportDate" class="java.util.Date"/>
	<parameter name="dateRange2ReportDate" class="java.util.Date" isForPrompting="false"/>
	<parameter name="Debug" class="java.lang.Boolean">
		<defaultValueExpression><![CDATA[false]]></defaultValueExpression>
	</parameter>
	<parameter name="IncludeCost" class="java.lang.Boolean">
		<defaultValueExpression><![CDATA[true]]></defaultValueExpression>
	</parameter>
	<parameter name="cbRepName" class="java.lang.String">
		<parameterDescription><![CDATA['%',All,'Thillens',Thillens,'Chad F',Chad F,'SPC',SPC,'Brinks I-Deposit',Brinks I-Deposit,'Fax',Fax,'Monthly',Monthly,'Rapid Armored',Rapid Armored,'Standard',Standard,'Brent M',Brent M,'Ashley W',Ashley W,'Robert Kodner. RK',Robert Kodner. RK]]></parameterDescription>
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT SO.ID,
	CUSTOMER.NAME,
	SO.NUM,
	SOITEM.ID AS SOITEMID,
    COALESCE(CAST(FIXES.DESCRIPTION AS DECIMAL), IF(COALESCE(IF(SOITEM.TOTALCOST = 0, POITEM.TOTALCOST,SOITEM.TOTALCOST),0)=0,PART.STDCOST * COALESCE(UC.FACTOR,1) * SOITEM.QTYTOFULFILL,COALESCE(IF(SOITEM.TOTALCOST = 0, POITEM.TOTALCOST,SOITEM.TOTALCOST),0)))  AS COST,
	SOITEM.TOTALPRICE AS PRICE,
	SOITEM.TOTALPRICE - COALESCE(CAST(FIXES.DESCRIPTION AS DECIMAL),IF(COALESCE(IF(SOITEM.TOTALCOST = 0, POITEM.TOTALCOST,SOITEM.TOTALCOST),0)=0,PART.STDCOST * COALESCE(UC.FACTOR,1) * SOITEM.QTYTOFULFILL,COALESCE(IF(SOITEM.TOTALCOST = 0, POITEM.TOTALCOST,SOITEM.TOTALCOST),0))) AS PROFIT,
	SOITEM.DESCRIPTION,
	SOITEM.PRODUCTNUM,
	customfieldbyid(customer.customfields, 46) AS REPNAME,
	SO.DATEISSUED,
	FIXES.DESCRIPTION
	FROM SO
INNER JOIN SOITEM ON SOITEM.SOID = SO.ID
INNER JOIN PRODUCT ON PRODUCT.ID = SOITEM.PRODUCTID
INNER JOIN PART ON PART.ID = PRODUCT.PARTID
INNER JOIN CUSTOMER ON CUSTOMER.ID = SO.CUSTOMERID


LEFT JOIN CUSTOMLISTITEM FIXES ON FIXES.NAME = SOITEM.ID AND FIXES.LISTID = 10
LEFT JOIN UOMCONVERSION UC ON UC.FROMUOMID = PART.UOMID AND UC.TOUOMID = SOITEM.UOMID

LEFT JOIN OBJECTTOOBJECT SOTOPO ON SOTOPO.RECORDID1 = SOITEM.ID AND SOTOPO.TYPEID = 10
LEFT JOIN POITEM ON POITEM.ID = SOTOPO.RECORDID2
WHERE
	PART.TYPEID < 40 AND
	SO.STATUSID > 10 AND
	SO.DATEISSUED between $P{dateRange1ReportDate} AND DATE_SUB($P{dateRange2ReportDate}, INTERVAL 1 SECOND) AND
COALESCE(customfieldbyid(customer.customfields, 46), ' ') LIKE ($P!{cbRepName})



ORDER BY
	CUSTOMER.NAME,
	SO.NUM]]>
	</queryString>
