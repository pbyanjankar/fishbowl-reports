	<subDataset name="CustomerInfo" uuid="4b15957a-182e-4442-9265-e7e84736377e">
		<parameter name="module" class="java.lang.Object" isForPrompting="false">
			<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
		</parameter>
		<parameter name="customerID" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["1"]]></defaultValueExpression>
		</parameter>
		<parameter name="cbCustomerStatus" class="java.lang.String" isForPrompting="false">
			<property name="Group" value="Filters"/>
			<property name="Sort" value="1"/>
			<parameterDescription><![CDATA[all,All,1,Active,0,Inactive]]></parameterDescription>
			<defaultValueExpression><![CDATA["all"]]></defaultValueExpression>
		</parameter>
		<parameter name="cbCustomerGroup" class="java.lang.String" isForPrompting="false">
			<property name="Group" value="Filters"/>
			<property name="Sort" value="1"/>
			<parameterDescription><![CDATA[all,All,Weekly Call,Weekly Call,Monthly Call,Monthly Call]]></parameterDescription>
			<defaultValueExpression><![CDATA["all"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT
    DISTINCT
    CUSTOMER.NAME AS CUSTOMER,
    latestSo.DATELASTORDER,
    telephoneContact.contact AS CONTACT,
    telephoneContact.telephone AS TELEPHONE

FROM
    customer
    LEFT OUTER JOIN (
	SELECT customerId, max(so.dateIssued) AS DATELASTORDER FROM so
	GROUP BY customerId
    ) AS latestSo ON latestSo.customerId = customer.id

    LEFT OUTER JOIN (
     	 SELECT
 		contact.contactName AS contact,
		contact.datus AS telephone,
 		customer.id AS customerId
           FROM
		contact
		INNER JOIN address ON address.accountid = contact.accountid and address.typeid = 50 and address.id = contact.addressid
        INNER JOIN customer ON customer.accountid = address.accountid
		INNER JOIN contacttype ON contact.typeid = contacttype.id AND upper(contacttype.name)  = 'MAIN'
        WHERE contact.defaultFlag=1) AS telephoneContact ON telephoneContact.customerid = customer.id

    LEFT OUTER JOIN (select accountId, accountgroup.name as groupName
    		from accountgroup
    		INNER JOIN accountgrouprelation ON accountgroup.id = accountgrouprelation.groupid
   		WHERE UPPER(accountgroup.name) IN ("WEEKLY CALL", "MONTHLY CALL")) AS result ON result.accountid = customer.accountid

WHERE
    customer.id LIKE $P{customerID}
    AND if($P{cbCustomerStatus} = 'all', 1=1, customer.activeFlag = $P{cbCustomerStatus})
    AND if($P{cbCustomerGroup} = 'all', 1=1, UPPER(result.groupName) = UPPER($P{cbCustomerGroup}))
ORDER BY
    1,2]]>
		</queryString>
		<field name="CUSTOMER" class="java.lang.String"/>
		<field name="TELEPHONE" class="java.lang.String"/>
		<field name="CONTACT" class="java.lang.String"/>
		<field name="DATELASTORDER" class="java.sql.Timestamp"/>
		<variable name="PriceDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_PRICE")]]></variableExpression>
		</variable>
		<variable name="QtyDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_QTY")]]></variableExpression>
		</variable>
		<variable name="CostDecimal" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[System.getProperty("REPORT_DECIMAL_COST")]]></variableExpression>
		</variable>
		<variable name="DateFormat" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
		<variable name="isMultiCurrency" class="java.lang.Boolean">
			<variableExpression><![CDATA[com.evnt.eve.modules.CurrencyModule.isMultiCurrency()]]></variableExpression>
		</variable>
	</subDataset>
