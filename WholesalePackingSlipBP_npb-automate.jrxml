where
soitemtype.id IN (10,11,80) AND
((soitem.soid =$P{soId} and soitemtype.name <> "Shipping" and ObjectToObject.recordId2 is null)
OR
(soitem.soid =$P{soId} and soitemtype.name = "Shipping" and postsoitem.postsoid = $P{postSoId}))

) AS result
WHERE result.QTYSHIPPED > 0
ORDER BY SOLINEITEM;]]>
		</queryString>
