		</parameter>
		<parameter name="cbOrder" class="java.lang.String" isForPrompting="false">
			<property name="Group" value="Column Sorting"/>
			<property name="Sort" value="4"/>
			<parameterDescription><![CDATA[ASC,Ascending,DESC,Descending]]></parameterDescription>
			<defaultValueExpression><![CDATA["ASC"]]></defaultValueExpression>
		</parameter>
		<parameter name="dateRange1" class="java.util.Date" isForPrompting="false">
			<property name="Group" value="Select a date field and enter a date range"/>
			<parameterDescription><![CDATA[This Month]]></parameterDescription>
			<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
		</parameter>
		<parameter name="dateRange2" class="java.util.Date" isForPrompting="false">
			<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
		</parameter>
		<parameter name="cbSortBy" class="java.lang.String" isForPrompting="false">
			<property name="Group" value="Column Sorting"/>
			<property name="Sort" value="3"/>
			<parameterDescription><![CDATA[customer.name $P!{cbOrder},Customer,stateconst.code $P!{cbOrder},State/Province,maxso.LastOrderScheduledDate $P!{cbOrder},Last Order Schedule Date]]></parameterDescription>
			<defaultValueExpression><![CDATA["1"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT customer.name AS CUSTOMER,
       maxso.lastorderscheduleddate AS LastOrderScheduledDate,
       address.address AS ADDRESS,
       zip AS ZIPCODE,
       address.city AS CITY,
       stateconst.code AS STATE,
       coalesce(contact.datus, '') as EMAIL,
       group_concat(accountgroup.name) as ACCOUNTGROUP
FROM customer
     LEFT OUTER JOIN accountgrouprelation ON customer.accountid = accountgrouprelation.accountid
     LEFT OUTER JOIN accountgroup ON accountgrouprelation.groupid = accountgroup.id
     LEFT OUTER JOIN address ON customer.accountid = address.accountid AND address.typeid = 50 AND address.defaultflag = true
     LEFT OUTER JOIN stateconst On address.stateid = stateconst.id
     LEFT OUTER JOIN countryconst ON countryconst.id = address.countryid
	 LEFT OUTER JOIN contact ON contact.accountId = customer.accountid AND contact.typeid=60 AND contact.addressid = address.id AND contact.defaultflag = true
     INNER JOIN company ON company.id = 1
     LEFT OUTER JOIN (SELECT max(so.datefirstship) AS lastorderscheduleddate, so.customerid
                 FROM so
                 WHERE so.statusid IN (10,20,25,60,70)
                 GROUP BY so.customerid) AS maxso ON customer.id = maxso.customerid
     LEFT OUTER JOIN (SELECT DISTINCT so.customerid AS customerId
                 FROM so
                 WHERE so.statusid IN (10,20,25,60,70)
		  AND so.datefirstship BETWEEN $P{dateRange1}  AND $P{dateRange2}
                ) AS sofilter ON customer.id = sofilter.customerid


WHERE sofilter.customerId IS NULL
  AND customer.activeFlag IN (1, $P!{ckShowInactiveCustomers})
  AND customer.id LIKE $P{customerID}

GROUP BY 1,2,3,4,5,6,7

ORDER BY $P!{cbSortBy}]]>
		</queryString>
		<field name="CUSTOMER" class="java.lang.String"/>
		<field name="LastOrderScheduledDate" class="java.sql.Timestamp"/>
		<field name="STATE" class="java.lang.String"/>
		<field name="ACCOUNTGROUP" class="java.lang.String"/>
		<field name="EMAIL" class="java.lang.String"/>
		<field name="ZIPCODE" class="java.lang.String"/>
		<field name="CITY" class="java.lang.String"/>
		<field name="ADDRESS" class="java.lang.String"/>
		<variable name="DateFormat" class="java.lang.String" resetType="None">
			<variableExpression><![CDATA[(System.getProperty("REPORT_DATE_FORMAT"))]]></variableExpression>
		</variable>
	</subDataset>
