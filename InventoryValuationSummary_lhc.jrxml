	<parameter name="path" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Program Files/Fishbowl/Server/reports/Inventory/"]]></defaultValueExpression>
	</parameter>
	<parameter name="module" class="java.lang.Object" isForPrompting="false">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="REPORTDESCRIPTION" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Generates a summary of the quantity and value of all parts currently on hand. Cost values are based on today's costs."]]></defaultValueExpression>
	</parameter>
	<parameter name="partNum" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="AssetAccount" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="cbCostingMethod" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[Average Cost, Average Cost, Standard Cost, Standard Cost]]></parameterDescription>
		<defaultValueExpression><![CDATA["Average Cost"]]></defaultValueExpression>
	</parameter>
	<parameter name="productTree1" class="java.lang.String" isForPrompting="false"/>
	<parameter name="productTree2" class="java.lang.String" isForPrompting="false"/>
	<parameter name="ckShowInactiveParts" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[0,100]]></parameterDescription>
		<defaultValueExpression><![CDATA["100"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    COALESCE(producttree.name, '{Not Assigned}') AS PRODUCTTREENAME,
    COALESCE(PARTCOST.AVGCOST, 0) AS AVERAGEUNITCOST,
    COALESCE(PART.STDCOST, 0) AS STANDARDUNITCOST,
    PART.NUM AS PARTNUMBER,
    PART.DESCRIPTION AS PARTDESCRIPTION, ASACCOUNT.NAME AS INVENTORYACCOUNT,
    UOM.CODE AS UOMCODE, SUM(TAG.QTY) AS QTY, COMPANY.NAME AS COMPANY, CURRENCY.SYMBOL

FROM part
    INNER JOIN partcost ON part.id = partcost.partid
    INNER JOIN tag ON part.id = tag.partid
    INNER JOIN product ON product.PARTID = part.ID
    LEFT JOIN asaccount ON part.inventoryaccountid = asaccount.id
    LEFT JOIN uom ON uom.id = part.uomid
    JOIN company ON company.id = 1
    LEFT JOIN currency ON currency.homeCurrency = 1
    LEFT OUTER JOIN producttotree ON producttotree.PRODUCTID = product.ID
    LEFT OUTER JOIN producttree ON producttotree.PRODUCTTREEID = producttree.ID

WHERE UPPER(part.num) LIKE UPPER($P{partNum})
  AND part.id > 0
    AND part.activeFlag IN (1,$P!{ckShowInactiveParts})
  AND (UPPER(asaccount.name) LIKE UPPER($P{AssetAccount}) OR (CASE WHEN $P{AssetAccount} = CAST('%' AS char(256)) THEN asaccount.name else 1 end ) is null)
 AND (
        COALESCE(producttree.id,0) IN ($P!{productTree1})
        OR COALESCE(producttree.id,0) LIKE $P{productTree2}
    )

GROUP BY 1, averageunitcost, standardunitcost, partnumber, partdescription, inventoryaccount, uomcode, company, currency.symbol

ORDER BY 1, part.num]]>
	</queryString>
	<field name="PRODUCTTREENAME" class="java.lang.String"/>
	<field name="AVERAGEUNITCOST" class="java.lang.Double"/>
	<field name="STANDARDUNITCOST" class="java.lang.Double"/>
