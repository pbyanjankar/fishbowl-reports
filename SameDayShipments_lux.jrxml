			<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
		</parameter>
		<parameter name="productNum" class="java.lang.String" isForPrompting="false">
			<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
		</parameter>
		<parameter name="cbApplyDateFilter" class="java.lang.String" isForPrompting="false">
			<property name="Group" value="Select a date field and enter a date range"/>
			<property name="Sort" value="2"/>
			<parameterDescription><![CDATA[so.dateCreated,SO Date Created,so.dateIssued,SO Date Issued,so.datecompleted,SO Date Completed,ship.dateCreated,Ship Date Created,ship.dateShipped,Date Shipped]]></parameterDescription>
			<defaultValueExpression><![CDATA["so.datecompleted"]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[SELECT
    SO.NUM AS SONUMBER,
    product.num AS PRODUCTNUMBER,
    SO.dateIssued AS DATEISSUED,
    SO.dateCompleted AS DATECOMPLETED,
    SO.dateCreated AS DATECREATED,
    sostatus.name AS SOSTATUS,
    ship.dateCreated AS SHIPDATECREATED,
    ship.dateShipped AS DATESHIPPED,
    shipitem.qtyShipped AS QTYSHIPPED,
    shipstatus.name AS SHIPSTATUS,
    customfieldbyname(so.customfields, "Order Received after 1:30") AS OrderReceivedAfter130,
    coalesce((select username from so_aud
where so_aud.id=so.id and so_aud.statusid=20
order by so_aud.dateissued desc limit 1),'') as IssuedUser,
coalesce((select COALESCE(memo.memo,'')  from MEMO
where memo.tableid = '1012013120'
and memo.recordid = so.id order by datecreated desc limit 1
),'') as MEMO
FROM
    so
    INNER JOIN sostatus ON sostatus.id = so.statusid
    INNER JOIN soitem ON soitem.soid = so.id
    INNER JOIN product ON product.id = soitem.productId
    LEFT OUTER JOIN shipitem ON shipitem.soitemid = soitem.id
    LEFT OUTER JOIN ship ON ship.id = shipitem.shipid
    LEFT OUTER JOIN shipstatus ON shipstatus.id = ship.statusId
    LEFT OUTER JOIN memo ON memo.recordId = so.id AND memo.tableid = '1012013120'
WHERE
    so.num LIKE $P{soNum}
    AND COALESCE(product.num,'') LIKE $P{productNum}
    AND $P!{cbApplyDateFilter} BETWEEN $P{dateRange1} AND $P{dateRange2}
ORDER BY
    1,2]]>
		</queryString>
		<field name="DATEISSUED" class="java.sql.Timestamp"/>
		<field name="DATECREATED" class="java.sql.Timestamp"/>
		<field name="SONUMBER" class="java.lang.String"/>
		<field name="SOSTATUS" class="java.lang.String"/>
		<field name="DATECOMPLETED" class="java.sql.Timestamp"/>
		<field name="PRODUCTNUMBER" class="java.lang.String"/>
		<field name="SHIPDATECREATED" class="java.sql.Timestamp"/>
		<field name="DATESHIPPED" class="java.sql.Timestamp"/>
		<field name="SHIPSTATUS" class="java.lang.String"/>
		<field name="QTYSHIPPED" class="java.lang.Double"/>
		<field name="MEMO" class="java.lang.String"/>
		<field name="OrderReceivedAfter130" class="java.lang.String"/>
