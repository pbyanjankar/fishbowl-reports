	</parameter>
	<parameter name="ckOrderStatusExpired" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[30,100]]></parameterDescription>
		<defaultValueExpression><![CDATA["30"]]></defaultValueExpression>
	</parameter>
	<parameter name="ItemIssue" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<parameter name="cbItemType" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[%,All,10,Credit,20,Replacement,30,Substitution,40,Repair]]></parameterDescription>
		<defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT RMA.NUM AS RMANUM, CUSTOMER.NAME AS RMACUSTOMER, RMASTATUS.NAME AS RMASTATUS, RMA.DATECREATED AS RMADATECREATED,
    RMA.DATEEXPIRES AS RMADATEEXPIRES, LOCATIONGROUP.NAME AS RMALOCATIONGROUP,
    RMAITEM.LINENUM AS RMALINENUM, ITEM.NUM AS RMAITEMPRODUCTNUM, ITEM.DESCRIPTION AS RMAITEMPRODUCTDESCRIPTION,
    RMAITEM.QTY AS RMAITEMQTY, UOM.CODE AS RMAITEMUOMCODE, RMAITEMTYPE.NAME AS RMAITEMTYPE, ISSUE.NAME AS RMAITEMISSUE,
    RESOLUTION.NAME AS RMAITEMRESOLUTION, SUB.NUM AS RMAITEMSUBPRODUCTNUM, SUB.DESCRIPTION AS RMAITEMSUBPRODUCTDESCRIPTION,
    RMAITEM.CROSSSHIPFLAG AS RMAITEMCROSSSHIPFLAG, RMAITEM.SHIPFLAG AS RMAITEMSHIPFLAG, RMAITEM.RETURNFLAG AS RMAITEMRETURNFLAG,
    VENDOR.NAME AS RMAITEMVENDORNAME, RMAITEM.VENDORRMA AS RMAITEMVENDORRMA, RMAITEM.DATERESOLVED AS RMADATERESOLVED,
    RMAITEM.NOTE AS RMAITEMNOTE,
    COMPANY.NAME AS COMPANY,
    DATEDIFF(CURRENT_DATE, RMA.DATECREATED) AS RMATAT,
    DATEDIFF(CURRENT_DATE, RMAITEM.DATERESOLVED) AS RMAITEMRESOLVEDTAT,
    result2.num AS PONUMBER,
    sysuser.username AS CREATEDBY,
    so.num AS SONUMBER

FROM customer, rmastatus, locationgroup, rma
    LEFT JOIN rmaitem ON rma.id = rmaitem.rmaid
    LEFT JOIN product AS item ON rmaitem.productid = item.id
    LEFT JOIN uom ON rmaitem.uomid = uom.id
    LEFT JOIN customlistitem issue ON rmaitem.issueid = issue.id
    LEFT JOIN customlistitem resolution ON rmaitem.resolutionid = resolution.id
    LEFT JOIN rmaitemtype ON rmaitem.typeid = rmaitemtype.id
    LEFT JOIN product AS sub ON rmaitem.productsubid = sub.id
    LEFT JOIN vendor ON rmaitem.vendorid = vendor.id

    LEFT OUTER JOIN (SELECT t.ID, t.UserID
		FROM rma_aud t
		JOIN (
    			SELECT ID, MIN(rev) AS first_rev
    			FROM rma_aud
    			GROUP BY ID
			) first_record
		ON t.ID = first_record.ID
		AND t.rev = first_record.first_rev) AS firstrma ON firstrma.ID = rma.id
    LEFT OUTER JOIN sysuser ON sysuser.id = firstrma.USERID


    JOIN company ON company.id = 1
    LEFT OUTER JOIN
	(SELECT po.num, result.rmaitemId FROM trackinginfosn
		INNER JOIN
			(SELECT trackinginfosn.serialNum, trackinginfo.recordId AS rmaitemId  FROM trackinginfo
    		           INNER JOIN trackinginfosn ON trackinginfo.id = trackinginfosn.trackinginfoid
    			 WHERE trackinginfo.tableid = -183091242
			) result on result.serialNum = trackinginfosn.serialNum
		INNER JOIN trackingInfo ON trackingInfo.id = trackinginfosn.trackinginfoid AND trackingInfo.tableid = 1259138490
		INNER JOIN receiptitem ON receiptitem.id = trackingInfo.recordid
		INNER JOIN poitem ON poitem.id = receiptitem.poitemid
		INNER JOIN po ON poitem.poid = po.id
	) AS result2 ON result2.rmaitemId = rmaitem.id


	LEFT OUTER JOIN objecttoobject oo ON rmaitem.id =  oo.recordId1 AND oo.tableid1 = -183091242 AND oo.tableid2 = 1002104832 AND oo.typeId = 20 AND oo.note = "Original Sales Order"
	LEFT OUTER JOIN soitem orgSoItem ON orgSoItem.id = oo.recordId2
          LEFT OUTER JOIN so ON orgSoItem.soid = so.id

WHERE rma.num LIKE $P{rmaNum}
  AND rma.customerid = customer.id
  AND rma.statusid = rmastatus.id
  AND locationgroup.id = rma.locationgroupid
  AND rma.datecreated BETWEEN $P{dateRange1} AND DATE_SUB($P{dateRange2}, INTERVAL 1 SECOND)
  AND rma.statusid IN ($P!{ckOrderStatusOpen},$P!{ckOrderStatusFulfilled},$P!{ckOrderStatusExpired})
  AND rmaitem.typeid LIKE $P{cbItemType}
  AND rma.locationgroupid IN ($P!{locationGroupID})
  AND item.num LIKE $P{productNum}
  AND rma.customerid LIKE $P{customerID}
  AND COALESCE(issue.name,'') LIKE (CONCAT('%' , $P{ItemIssue} , '%'))

ORDER BY locationgroup.name, $P!{ckOrderByCustomer}, rma.num, rmaitem.linenum]]>
	</queryString>
